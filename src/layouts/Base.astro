---
import "../styles/global.css";
import WhatsAppFab from "../components/WhatsAppFab.astro";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#05111D" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Per-page SEO meta (title, description, OG, canonical, hreflang) injected via SEO.astro -->
    <slot name="head" />
  </head>
  <body>
    <!-- Skip-to-content: visible on focus for keyboard/AT users -->
    <a href="#main" class="skip-link">Skip to content</a>
    <div id="main">
      <slot />
    </div>
    <WhatsAppFab />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 9999;
    padding: 12px 24px;
    background: #4A8FE7;
    color: #FAFBFD;
    font-family: system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border-bottom-right-radius: 6px;
    transition: top 0.1s;
  }

  .skip-link:focus {
    top: 0;
    outline: 2px solid #FAFBFD;
    outline-offset: -4px;
  }
</style>
