---
import Base from "./Base.astro";
import IntelHeader from "../components/IntelHeader.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  jurisdiction: { country: string; scope: string; region?: string };
  author: string;
  created: Date;
  updated: Date;
  word_count?: number;
  sources_count?: number;
  tags?: string[];
}

const { title, description, jurisdiction, author, created, updated, word_count, sources_count, tags = [] } =
  Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const countryName: Record<string, string> = {
  BR: "Brazil", MX: "Mexico", CL: "Chile", AR: "Argentina",
  CO: "Colombia", PE: "Peru", UY: "Uruguay",
};
---

<Base title={`${title} — CMP Technical Memo`} description={description}>
  <IntelHeader active="memos" />

  <main class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm text-light-muted mb-6">
      <a href="/intelligence/memos" class="hover:text-blue">← All memos</a>
    </nav>

    <header class="mb-10 pb-8 border-b border-light-border">
      <div class="flex flex-wrap gap-2 text-xs uppercase tracking-wider text-blue font-semibold mb-3">
        <span>{countryName[jurisdiction.country] ?? jurisdiction.country}</span>
        <span>·</span>
        <span>{jurisdiction.scope}</span>
        {jurisdiction.region && (
          <>
            <span>·</span>
            <span>{jurisdiction.region}</span>
          </>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-heading font-bold leading-tight text-light-text">{title}</h1>
      <div class="mt-5 flex flex-wrap gap-x-6 gap-y-1 text-sm text-light-muted">
        <span>Author: <span class="text-light-text">{author}</span></span>
        <span>Published: {fmtDate(created)}</span>
        {updated > created && <span>Updated: {fmtDate(updated)}</span>}
        {word_count && <span>{word_count} words</span>}
        {sources_count !== undefined && <span>{sources_count} primary sources</span>}
      </div>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <span class="text-xs px-2 py-1 bg-light-surface text-light-muted rounded">{t}</span>
          ))}
        </div>
      )}
    </header>

    <article class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-light-text prose-a:text-blue">
      <slot />
    </article>

    <footer class="mt-16 pt-8 border-t border-light-border text-sm text-light-muted">
      <p>
        © 2026 Cloud Minds Partners. Published technical memo. Citations trace
        to primary sources audited via
        <code class="text-xs bg-light-surface px-1 py-0.5 rounded">cmp-memo audit</code>.
      </p>
    </footer>
  </main>
</Base>
