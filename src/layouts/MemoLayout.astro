---
import Base from "./Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description?: string;
  jurisdiction: { country: string; scope: string; region?: string };
  author: string;
  created: Date;
  updated: Date;
  word_count?: number;
  sources_count?: number;
  tags?: string[];
}

const { title, description, jurisdiction, author, created, updated, word_count, sources_count, tags = [] } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const countryName: Record<string, string> = {
  BR: "Brazil", MX: "Mexico", CL: "Chile", AR: "Argentina",
  CO: "Colombia", PE: "Peru", UY: "Uruguay",
};
---

<Base title={`${title} — CMP Technical Memo`} description={description}>
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos", active: true },
      { href: "/intelligence/radar", label: "Innovation Radar" },
      { href: "/intelligence/regwatch", label: "Regulatory Watch" },
    ]}
  />

  <main class="max-w-[720px] mx-auto px-6 py-16">
    <nav class="caption mb-10">
      <a href="/intelligence/memos" class="no-underline">← All memos</a>
    </nav>

    <header class="mb-12 pb-8 border-b border-[var(--color-rule)]">
      <div class="caption text-[var(--color-navy)] mb-4">
        {countryName[jurisdiction.country] ?? jurisdiction.country} · {jurisdiction.scope}
        {jurisdiction.region && <> · {jurisdiction.region}</>}
      </div>
      <h1 class="display text-4xl md:text-5xl leading-tight tracking-tight">{title}</h1>
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-1 text-sm text-[var(--color-ink-muted)]">
        <span>Author: <span class="text-[var(--color-ink)]">{author}</span></span>
        <span>Published: {fmtDate(created)}</span>
        {updated > created && <span>Updated: {fmtDate(updated)}</span>}
        {word_count && <span class="tabular-nums">{word_count} words</span>}
        {sources_count !== undefined && <span class="tabular-nums">{sources_count} primary sources</span>}
      </div>
      {tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.map((t) => (
            <span class="caption px-2 py-1 bg-[var(--color-surface-alt)] border border-[var(--color-rule)]">{t}</span>
          ))}
        </div>
      )}
    </header>

    <article class="prose prose-lg">
      <slot />
    </article>

    <footer class="mt-16 pt-8 border-t border-[var(--color-rule)] text-xs text-[var(--color-ink-quiet)] leading-relaxed">
      © 2026 Cloud Minds Partners. Citations audited via <code class="bg-[var(--color-surface-alt)] px-1 py-0.5">cmp-memo audit</code> —
      every <code class="bg-[var(--color-surface-alt)] px-1 py-0.5">[src:...]</code> token in the body resolves to a primary
      source downloaded to our intelligence repository.
    </footer>
  </main>

  <SiteFooter />
</Base>
