---
import Base from "./Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  month: string;
  author: string;
  description?: string;
}

const { month, author, description } = Astro.props;

const [y, m] = month.split("-").map(Number);
const label = y && m
  ? new Date(y, m - 1, 1).toLocaleDateString("en-US", { year: "numeric", month: "long" })
  : month;
---

<Base title={`Regulatory Watch — ${label}`} description={description}>
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos" },
      { href: "/intelligence/radar", label: "Innovation Radar" },
      { href: "/intelligence/regwatch", label: "Regulatory Watch", active: true },
    ]}
  />

  <main class="max-w-[720px] mx-auto px-6 py-16">
    <nav class="caption mb-10">
      <a href="/intelligence/regwatch" class="no-underline">← All digests</a>
    </nav>

    <header class="mb-12 pb-8 border-b border-[var(--color-rule)]">
      <div class="caption text-[var(--color-navy)] mb-4">Regulatory Watch</div>
      <h1 class="display text-4xl md:text-5xl leading-tight tracking-tight">{label}</h1>
      <div class="mt-5 text-sm text-[var(--color-ink-muted)]">
        Author: <span class="text-[var(--color-ink)]">{author}</span>
      </div>
    </header>

    <article class="prose prose-lg">
      <slot />
    </article>
  </main>

  <SiteFooter />
</Base>
