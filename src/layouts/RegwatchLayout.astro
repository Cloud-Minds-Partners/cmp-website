---
import Base from "./Base.astro";
import SEO from "../components/SEO.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  month: string;
  author: string;
  description?: string;
}

const { month, author, description } = Astro.props;

const [y, m] = month.split("-").map(Number);
const label = y && m
  ? new Date(y, m - 1, 1).toLocaleDateString("en-US", { year: "numeric", month: "long" })
  : month;

const locale = Astro.currentLocale ?? "en";

// Article JSON-LD (CONT-07)
const datePublished = (y && m) ? new Date(y, m - 1, 1).toISOString() : new Date().toISOString();
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${label} Regulatory Watch`,
  author: { "@type": "Person", name: author },
  datePublished,
  dateModified: datePublished,
  publisher: { "@type": "Organization", name: "Cloud Minds Partners" },
};
---

<Base lang={locale}>
  <SEO
    slot="head"
    title={`Regulatory Watch — ${label}`}
    description={description ?? `CMP Regulatory Watch digest for ${label}.`}
    type="article"
    lang={locale}
  >
    <script slot="json-ld" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </SEO>

  <SiteHeader
    subnav={[
      { href: getRelativeLocaleUrl(locale, "intelligence"), label: "Overview" },
      { href: getRelativeLocaleUrl(locale, "intelligence/memos"), label: "Technical Memos" },
      { href: getRelativeLocaleUrl(locale, "intelligence/radar"), label: "Innovation Radar" },
      { href: getRelativeLocaleUrl(locale, "intelligence/regwatch"), label: "Regulatory Watch", active: true },
    ]}
  />

  <main class="max-w-[720px] mx-auto px-6 py-16">
    <nav class="caption mb-10">
      <a href={getRelativeLocaleUrl(locale, "intelligence/regwatch")} class="no-underline">← All digests</a>
    </nav>

    <header class="mb-12 pb-8 border-b border-[var(--color-rule)]">
      <div class="caption text-[var(--color-navy)] mb-4">Regulatory Watch</div>
      <h1 class="display text-4xl md:text-5xl leading-tight tracking-tight">{label}</h1>
      <div class="mt-5 text-sm text-[var(--color-ink-muted)]">
        Author: <span class="text-[var(--color-ink)]">{author}</span>
      </div>
    </header>

    <article class="prose prose-lg">
      <slot />
    </article>
  </main>

  <SiteFooter />
</Base>
