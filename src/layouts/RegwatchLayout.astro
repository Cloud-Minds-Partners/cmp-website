---
import V4Layout from "../components/v4/V4Layout.astro";

interface Props {
  month: string;
  author: string;
  description?: string;
}

const { month, author, description } = Astro.props;

const [y, m] = month.split("-").map(Number);
const label = y && m
  ? new Date(y, m - 1, 1).toLocaleDateString("en-US", { year: "numeric", month: "long" })
  : month;
---

<V4Layout title={`Regulatory Watch — ${label}`} description={description} active="intelligence">
  <section class="v4-section v4-section-light" style="padding-top:56px; padding-bottom:0;">
    <div class="v4-prose-container">
      <nav style="margin-bottom:32px;">
        <a href="/intelligence/regwatch" class="v4-back-link">← All digests</a>
      </nav>

      <header class="v4-prose-header">
        <div class="v4-memo-jurisdiction">Regulatory Watch</div>
        <h1 class="v4-display-lg" style="margin-top:16px; margin-bottom:24px;">{label}</h1>
        <div class="v4-memo-byline">
          <span>Author: <strong>{author}</strong></span>
        </div>
      </header>
    </div>
  </section>

  <section class="v4-section v4-section-light" style="padding-top:48px;">
    <div class="v4-prose-container">
      <article class="v4-prose">
        <slot />
      </article>
    </div>
  </section>
</V4Layout>

<style>
  .v4-prose-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .v4-back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-ink-quiet);
    text-decoration: none;
  }
  .v4-back-link:hover { color: var(--color-rust); }
  .v4-memo-jurisdiction {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-navy);
  }
  .v4-prose-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: 48px;
  }
  .v4-memo-byline {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink-muted);
  }
  .v4-memo-byline strong { color: var(--color-ink); font-weight: 500; }

  .v4-prose {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-ink);
  }
  .v4-prose :global(h1) { display: none; }
  .v4-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    margin: 48px 0 16px;
  }
  .v4-prose :global(h3) {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 32px 0 12px;
    color: var(--color-ink-muted);
  }
  .v4-prose :global(p) { margin: 0 0 20px; }
  .v4-prose :global(ul), .v4-prose :global(ol) { margin: 0 0 20px; padding-left: 24px; }
  .v4-prose :global(li) { margin: 6px 0; }
  .v4-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 32px 0;
    font-size: 14px;
  }
  .v4-prose :global(th) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 10px 16px;
    text-align: left;
    border-bottom: 2px solid var(--color-rule);
    color: var(--color-ink-muted);
  }
  .v4-prose :global(td) {
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-rule);
  }
  .v4-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: 2px 6px;
  }
  .v4-prose :global(a) { color: var(--color-navy); }
  .v4-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: 40px 0;
  }
</style>
