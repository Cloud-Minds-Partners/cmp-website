---
import Base from "./Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  week: string;
  period_start: Date;
  period_end: Date;
  author: string;
  description?: string;
}

const { week, period_start, period_end, author, description } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const hasRange = period_start.valueOf() > 0 && period_end.valueOf() > 0;
---

<Base title={`Innovation Radar — Week ${week}`} description={description}>
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos" },
      { href: "/intelligence/radar", label: "Innovation Radar", active: true },
      { href: "/intelligence/regwatch", label: "Regulatory Watch" },
    ]}
  />

  <main class="max-w-[720px] mx-auto px-6 py-16">
    <nav class="caption mb-10">
      <a href="/intelligence/radar" class="no-underline">← All radar entries</a>
    </nav>

    <header class="mb-12 pb-8 border-b border-[var(--color-rule)]">
      <div class="caption text-[var(--color-navy)] mb-4">Innovation Radar</div>
      <h1 class="display text-4xl md:text-5xl leading-tight tracking-tight">Week {week}</h1>
      <div class="mt-5 flex flex-wrap gap-x-6 gap-y-1 text-sm text-[var(--color-ink-muted)]">
        {hasRange && <span>{fmtDate(period_start)} — {fmtDate(period_end)}</span>}
        <span>Author: <span class="text-[var(--color-ink)]">{author}</span></span>
      </div>
    </header>

    <article class="prose prose-lg">
      <slot />
    </article>
  </main>

  <SiteFooter />
</Base>
