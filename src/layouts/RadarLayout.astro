---
import Base from "./Base.astro";
import SEO from "../components/SEO.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  week: string;
  period_start: Date;
  period_end: Date;
  author: string;
  description?: string;
}

const { week, period_start, period_end, author, description } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const hasRange = period_start.valueOf() > 0 && period_end.valueOf() > 0;

const locale = Astro.currentLocale ?? "en";

// Article JSON-LD (CONT-05)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `Innovation Radar — Week ${week}`,
  author: { "@type": "Person", name: author },
  datePublished: hasRange ? period_start.toISOString() : new Date().toISOString(),
  dateModified: hasRange ? period_end.toISOString() : new Date().toISOString(),
  publisher: { "@type": "Organization", name: "Cloud Minds Partners" },
};
---

<Base lang={locale}>
  <SEO
    slot="head"
    title={`Innovation Radar — Week ${week}`}
    description={description ?? `CMP Innovation Radar weekly digest for ${week}.`}
    type="article"
    lang={locale}
  >
    <script slot="json-ld" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </SEO>

  <SiteHeader
    subnav={[
      { href: getRelativeLocaleUrl(locale, "intelligence"), label: "Overview" },
      { href: getRelativeLocaleUrl(locale, "intelligence/memos"), label: "Technical Memos" },
      { href: getRelativeLocaleUrl(locale, "intelligence/radar"), label: "Innovation Radar", active: true },
      { href: getRelativeLocaleUrl(locale, "intelligence/regwatch"), label: "Regulatory Watch" },
    ]}
  />

  <main class="max-w-[720px] mx-auto px-6 py-16">
    <nav class="caption mb-10">
      <a href={getRelativeLocaleUrl(locale, "intelligence/radar")} class="no-underline">← All radar entries</a>
    </nav>

    <header class="mb-12 pb-8 border-b border-[var(--color-rule)]">
      <div class="caption text-[var(--color-navy)] mb-4">Innovation Radar</div>
      <h1 class="display text-4xl md:text-5xl leading-tight tracking-tight">Week {week}</h1>
      <div class="mt-5 flex flex-wrap gap-x-6 gap-y-1 text-sm text-[var(--color-ink-muted)]">
        {hasRange && <span>{fmtDate(period_start)} — {fmtDate(period_end)}</span>}
        <span>Author: <span class="text-[var(--color-ink)]">{author}</span></span>
      </div>
    </header>

    <article class="prose prose-lg">
      <slot />
    </article>
  </main>

  <SiteFooter />
</Base>
