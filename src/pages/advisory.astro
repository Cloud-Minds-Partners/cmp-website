---
import V4Layout from "../components/v4/V4Layout.astro";
import TierRadar from "../components/v4/TierRadar.astro";

const capabilities = [
  {
    n: "01",
    t: "Site selection",
    b: "Multi-criteria scoring across land, power, water, connectivity, tax, and regulatory fit. Driven by our Site Selection Tool and ground-truthed with local partners.",
  },
  {
    n: "02",
    t: "Feasibility studies",
    b: "Capex envelope, timeline risk, interconnection gate, water baseline, permitting path. Output is a defensible file deliverable, not a pitch deck.",
  },
  {
    n: "03",
    t: "Market intelligence",
    b: "Demand signals, competitive density, tariff trajectories, and policy context across Brazil, Chile, and Mexico as primary markets.",
  },
  {
    n: "04",
    t: "Regulatory path mapping",
    b: "Federal, state, and municipal requirements distilled into a project timeline. Primary sources attached. Reviewed monthly under Regulatory Watch.",
  },
];

const stats = [
  { value: "76", label: "cities scored" },
  { value: "30+", label: "test-fit presets" },
  { value: "3", label: "primary countries" },
  { value: "1", label: "audit gate, no exceptions" },
];
---

<V4Layout title="Advisory — Cloud Minds Partners" description="Site selection, feasibility studies, market intelligence, and regulatory path mapping for data center projects in Latin America." active="advisory">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero has-visual">
    <div class="v4-page-hero-inner">
      <div>
        <span class="v4-eyebrow">01 / Advisory</span>
        <h1 class="v4-display-xl">
          Advisory for data center projects in <em class="v4-italic-rust">Latin America</em>.
        </h1>
        <p class="v4-lede">
          The work that sits before a project has a CFO and an EPC —
          deciding where, whether, and how, with evidence that holds up in
          front of a board, a regulator, or a bank.
        </p>
        <div class="v4-btn-row">
          <a href="/contact" class="v4-btn v4-btn-primary">Engage advisory →</a>
          <a href="/intelligence" class="v4-btn v4-btn-secondary">See our research</a>
        </div>
      </div>
      <div class="v4-tier-visual"><TierRadar /></div>
    </div>
  </section>

  <!-- ═══ STATS BAR ═══ -->
  <section class="v4-section v4-section-darker" style="padding-top:72px; padding-bottom:72px;">
    <div class="v4-section-inner">
      <div class="v4-stats" style="grid-template-columns: repeat(4, 1fr); margin: 0; border: none; padding: 0;">
        {stats.map((s) => (
          <div>
            <div class="v4-stat-value">{s.value}</div>
            <div class="v4-stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CAPABILITIES ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <span class="v4-eyebrow v4-eyebrow-light">Capabilities</span>
      <h2 class="v4-display-lg" style="margin-bottom:16px;">How we work.</h2>
      <p class="v4-lede v4-lede-light" style="margin-bottom:56px;">
        Four practices, one method: primary sources, audit gate, defensible deliverables.
      </p>
      <div class="v4-card-grid-2">
        {capabilities.map((c) => (
          <div class="v4-card">
            <div class="v4-card-num">{c.n}</div>
            <h3 class="v4-card-name">{c.t}</h3>
            <p class="v4-card-desc">{c.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ METHOD ═══ -->
  <section class="v4-section v4-section-dark">
    <div class="v4-section-narrow">
      <span class="v4-eyebrow">Method</span>
      <h2 class="v4-display-lg">Primary sources first. Always.</h2>
      <p class="v4-lede" style="font-size:20px; max-width:760px;">
        Every factual claim in a CMP deliverable traces back to a primary
        source downloaded and archived in our intelligence repository. We
        built an audit gate —
        <code style="font-family:var(--font-mono); font-size:15px; background:rgba(245,241,232,0.08); padding:2px 8px; border:1px solid var(--v4-rule-dark); border-radius:4px;">cmp-memo audit</code>
        — that blocks publication when citations don't resolve to a verifiable document.
      </p>
      <p class="v4-lede" style="margin-top:20px; max-width:760px;">
        This is unusual in the industry. It is not a marketing line. It is
        the constraint that shapes what we publish and when.
      </p>
    </div>
  </section>

  <!-- ═══ BIG CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Looking at a specific <em class="v4-italic-rust">site</em> or <em class="v4-italic-rust">market</em>?
      </h2>
      <p class="v4-big-cta-body">
        Send us the brief. First conversation is on us — we'll tell you
        whether it's a CMP-shaped problem or not, and what the next step looks like either way.
      </p>
      <a href="/contact" class="v4-btn v4-btn-primary v4-btn-large">Start a conversation →</a>
    </div>
  </section>
</V4Layout>
