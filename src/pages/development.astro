---
import V4Layout from "../components/v4/V4Layout.astro";
import TierIsometric from "../components/v4/TierIsometric.astro";

const phases = [
  {
    n: "Phase 1",
    t: "Pre-site",
    b: "Site qualification, offtake modeling, equity/debt stack scoping. Goal: committable term sheet within 90 days where fundamentals support it.",
  },
  {
    n: "Phase 2",
    t: "Engineering & permits",
    b: "Technical DD, interconnection path, environmental and water filings, MV/HV coordination. Managed with EPC and local engineering partners.",
  },
  {
    n: "Phase 3",
    t: "Construction & commissioning",
    b: "Owner-rep coordination, risk register, schedule-linked cash curve, milestone reporting. We stay close enough to catch drift without replacing the GC.",
  },
  {
    n: "Phase 4",
    t: "Operate & iterate",
    b: "PUE/WUE monitoring, expansion optioning, exit or refinancing prep. Intelligence inputs fed back into the Site Selection Tool for future deals.",
  },
];

const models = [
  { t: "Co-developer", b: "CMP holds a development interest alongside the sponsor. Aligned on outcome, not billable hour." },
  { t: "Owner's technical advisor", b: "Fixed-scope engagements covering technical DD, permitting, procurement support, and commissioning oversight." },
  { t: "Intelligence subscription", b: "For funds and strategic operators — ongoing access to platform data, memos, and monthly regulatory digests." },
];
---

<V4Layout title="Development — Cloud Minds Partners" description="Co-development, technical due diligence, and financial modeling for data center projects from pre-site through commissioning." active="development">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero has-visual">
    <div class="v4-page-hero-inner">
      <div>
        <span class="v4-eyebrow">02 / Project Development</span>
        <h1 class="v4-display-xl">
          From thesis to <em class="v4-italic-rust">commissioned asset</em>.
        </h1>
        <p class="v4-lede">
          We work alongside operators and sponsors on specific projects —
          as co-developer, technical advisor, or financial partner —
          across the full lifecycle of a data center build.
        </p>
        <div class="v4-btn-row">
          <a href="/contact" class="v4-btn v4-btn-primary">Bring us a project →</a>
          <a href="/advisory" class="v4-btn v4-btn-secondary">Pre-site advisory</a>
        </div>
      </div>
      <div class="v4-tier-visual"><TierIsometric /></div>
    </div>
  </section>

  <!-- ═══ PHASES ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <span class="v4-eyebrow v4-eyebrow-light">Project lifecycle</span>
      <h2 class="v4-display-lg" style="margin-bottom:16px;">Four phases. One owner of the narrative.</h2>
      <p class="v4-lede v4-lede-light" style="margin-bottom:56px;">
        Each phase has a defined gate, a primary deliverable, and a clear hand-off. Schedule, budget,
        and risk are tracked against a single project register.
      </p>
      <div class="v4-card-grid" style="grid-template-columns: repeat(4, 1fr);">
        {phases.map((p) => (
          <div class="v4-card" style="min-height:260px;">
            <div class="v4-card-num">{p.n.toUpperCase()}</div>
            <h3 class="v4-card-name" style="font-size:20px;">{p.t}</h3>
            <p class="v4-card-desc">{p.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ENGAGEMENT MODELS ═══ -->
  <section class="v4-section v4-section-dark">
    <div class="v4-section-inner">
      <span class="v4-eyebrow">Engagement models</span>
      <h2 class="v4-display-lg">How we participate.</h2>
      <p class="v4-lede" style="margin-bottom:56px;">
        Three forms of engagement, each with a different risk-share. Pick the one that maps
        to your phase and the rest follows.
      </p>
      <div class="v4-card-grid v4-card-grid-dark">
        {models.map((m, i) => (
          <div class="v4-card v4-card-dark">
            <div class="v4-card-num">{String(i+1).padStart(2,"0")}</div>
            <h3 class="v4-card-name">{m.t}</h3>
            <p class="v4-card-desc">{m.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BIG CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Have a project that needs<br/>
        a <em class="v4-italic-rust">co-developer</em> or a <em class="v4-italic-rust">sharper technical lens</em>?
      </h2>
      <p class="v4-big-cta-body">
        Send a one-pager. We come back with a yes/no/maybe and the scope of a first
        engagement within a week.
      </p>
      <a href="/contact" class="v4-btn v4-btn-primary v4-btn-large">Start a conversation →</a>
    </div>
  </section>
</V4Layout>
