---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
---

<Base lang="en">
  <SEO
    slot="head"
    title="Development — Cloud Minds Partners"
    description="From thesis to commissioned asset. Co-developer, technical advisor, or financial partner across the full build lifecycle."
    image="/og/development.png"
  />

  <style slot="head" is:global>
    .page-hero-bg { background-image: url("/photos/hero-development.jpg"); }

    .roles { padding: clamp(96px, 14vh, 160px) 0; background: var(--cream-bg); color: var(--navy-0); }
    .roles-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 64px;
    }
    .role-card {
      background: transparent;
      border: 1px solid rgba(5,14,29,0.12);
      border-radius: 20px;
      padding: 0;
      display: flex; flex-direction: column;
      text-align: center;
      overflow: hidden;
      min-height: 420px;
      transition: border-color var(--t-base), transform var(--t-base), box-shadow var(--t-base);
    }
    .role-card:hover {
      border-color: rgba(45,107,228,0.55);
      transform: translateY(-3px);
      box-shadow: 0 18px 44px rgba(45,107,228,0.12);
    }
    .role-photo {
      width: 100%; height: 200px;
      background-size: cover; background-position: center;
      filter: saturate(1.18) contrast(1.05);
      transition: transform var(--t-slow);
      border-radius: 19px 19px 0 0;
    }
    .role-card:hover .role-photo { transform: scale(1.04); }
    .role-body {
      padding: 32px 28px 36px;
      display: flex; flex-direction: column; gap: 12px;
      align-items: center; justify-content: center;
      flex: 1;
    }
    .role-num { font-family: var(--font-display); font-size: 13px; font-weight: 600; color: var(--blue-deep); letter-spacing: 0.04em; text-transform: uppercase; }
    .role-card h3 { font-family: var(--font-display); font-size: 28px; font-weight: 600; letter-spacing: -0.018em; margin: 0; color: var(--navy-0); }
    .role-card p { font-size: 16px; line-height: 1.55; color: #4D5F7A; margin: 0; max-width: 30ch; }

    .lifecycle { background: var(--navy-0); padding: clamp(96px, 14vh, 160px) 0; }
    .lifecycle-track {
      display: grid; grid-template-columns: repeat(4, 1fr);
      margin-top: 64px;
      border-top: 1px solid var(--line-0);
    }
    .lc-phase {
      padding: 40px 28px;
      border-right: 1px solid var(--line-0);
      text-align: center;
      display: flex; flex-direction: column; align-items: center; gap: 12px;
    }
    .lc-phase:last-child { border-right: 0; }
    .lc-num { font-family: var(--font-display); font-size: 56px; font-weight: 600; color: var(--blue-bright); line-height: 1; letter-spacing: var(--track-tight); }
    .lc-label { font-family: var(--font-body); font-size: 12.5px; color: var(--cream-3); }
    .lc-phase h4 { font-family: var(--font-display); font-size: 19px; font-weight: 600; margin: 0; color: var(--cream-0); letter-spacing: -0.012em; }
    .lc-phase p { font-size: 14px; line-height: 1.55; color: var(--cream-1); margin: 0; max-width: 28ch; }

    @media (max-width: 880px) {
      .roles-grid, .lifecycle-track { grid-template-columns: 1fr; }
      .lc-phase { border-right: 0; border-bottom: 1px solid var(--line-0); }
    }
  </style>

  <nav class="nav">
    <div class="nav-inner">
      <a class="brand" href="/"><img class="brand-wordmark" src="/logo/cmp-wordmark.png" alt="Cloud Minds Partners" /><span class="brand-tag">Data Center Advisory · LatAm</span></a>
      <div class="nav-links"><a href="/advisory">Advisory</a><a href="/development" class="active">Development</a><a href="/intelligence">Intelligence</a><a href="/platforms">Platforms</a><a href="/team">Team</a></div>
      <div class="nav-right"><div class="nav-lang">
        <a href="/development" class="active">EN</a><span class="sep">·</span><a href="/pt/">PT</a><span class="sep">·</span><a href="/es/">ES</a>
      </div>
      <a href="mailto:info@cloudmindspartners.com" class="nav-cta">Talk to us <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7h12M7 1l6 6-6 6"/></svg></a></div>
    </div>
  </nav>

  <header class="page-hero">
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="wrap">
      <div class="page-hero-content">
        <div class="page-eyebrow live">Development</div>
        <h1>From thesis to <em>commissioned asset.</em></h1>
        <p>Co-developer, technical advisor, or financial partner — across the full build lifecycle.</p>
      </div>
    </div>
  </header>

  <section class="roles on-cream">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <div class="section-eyebrow" style="justify-content:center;">Roles</div>
        <h2 class="section-heading" style="margin: 0 auto; max-width: 680px;">Three ways we sit on <span class="blue">the cap table.</span></h2>
      </div>
      <div class="roles-grid">
        <div class="role-card reveal reveal-delay-1">
          <div class="role-photo" style="background-image:url('/photos/card-dev-codeveloper.jpg');"></div>
          <div class="role-body">
            <div class="role-num">01 — Equity</div>
            <h3>Co-developer</h3>
            <p>Phase-gated equity tranches tied to project milestones.</p>
          </div>
        </div>
        <div class="role-card reveal reveal-delay-2">
          <div class="role-photo" style="background-image:url('/photos/card-dev-tech-advisor.jpg');"></div>
          <div class="role-body">
            <div class="role-num">02 — Fee-based</div>
            <h3>Technical advisor</h3>
            <p>DD for institutional investors and operators.</p>
          </div>
        </div>
        <div class="role-card reveal reveal-delay-3">
          <div class="role-photo" style="background-image:url('/photos/card-dev-financial-partner.jpg');"></div>
          <div class="role-body">
            <div class="role-num">03 — Capital</div>
            <h3>Financial partner</h3>
            <p>BNDES, IFC, debentures incentivadas and senior tranches.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="lifecycle">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <div class="section-eyebrow" style="justify-content:center;">Lifecycle</div>
        <h2 class="section-heading" style="margin: 0 auto; max-width: 720px;">Kickoff to <span class="blue">commissioning.</span></h2>
      </div>
    </div>
    <div class="lifecycle-track">
      <div class="lc-phase reveal reveal-delay-1">
        <div class="lc-num">01</div>
        <div class="lc-label">0–6 months</div>
        <h4>Pre-site</h4>
        <p>Qualification, offtake modeling, term sheet in 90 days.</p>
      </div>
      <div class="lc-phase reveal reveal-delay-2">
        <div class="lc-num">02</div>
        <div class="lc-label">6–18 months</div>
        <h4>Engineering &amp; permits</h4>
        <p>Technical DD, interconnection, environmental filings.</p>
      </div>
      <div class="lc-phase reveal reveal-delay-3">
        <div class="lc-num">03</div>
        <div class="lc-label">18–36 months</div>
        <h4>Construction</h4>
        <p>Owner-rep, risk register, milestone reporting.</p>
      </div>
      <div class="lc-phase reveal reveal-delay-3">
        <div class="lc-num">04</div>
        <div class="lc-label">Ongoing</div>
        <h4>Operate &amp; iterate</h4>
        <p>PUE/WUE monitoring, expansion, exit prep.</p>
      </div>
    </div>
  </section>

  <footer>
    <div class="foot-links">
      <div class="foot-brand-cell">
        <a class="brand" href="/"><img class="brand-wordmark" src="/logo/cmp-wordmark.png" alt="Cloud Minds Partners" /></a>
        <p>Data center intelligence for Latin America.</p>
        <div class="foot-social" aria-label="Follow us">
          <a href="https://www.linkedin.com/company/cloud-minds-partners" aria-label="LinkedIn" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.97 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0z"/></svg></a>
          <a href="https://wa.me/5511999999999" aria-label="WhatsApp" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.5-.6.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.7.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4 0-.1-.3-.2-.5-.3zM12 22a10 10 0 0 1-5-1.3L2 22l1.3-5A10 10 0 1 1 12 22zm0-18.2A8.2 8.2 0 0 0 4.6 16l-.2.5-.8 3 3-.8.5.2c1.2.7 2.6 1.1 4 1.1 4.5 0 8.2-3.7 8.2-8.2S16.5 3.8 12 3.8z"/></svg></a>
        </div>
      </div>
      <div><h4>Platforms</h4><ul><li><a href="/platforms">Site Selection</a></li><li><a href="/platforms">Grid Intelligence</a></li><li><a href="/platforms">Financial Model</a></li><li><a href="/platforms">Test Fit Pro</a></li></ul></div>
      <div><h4>Intelligence</h4><ul><li><a href="/intelligence">Technical Memos</a></li><li><a href="/intelligence">Innovation Radar</a></li><li><a href="/intelligence">Regulatory Watch</a></li><li><a href="/intelligence">Weekly Pulse</a></li></ul></div>
      <div><h4>Company</h4><ul><li><a href="/advisory">Advisory</a></li><li><a href="/development">Development</a></li><li><a href="/team">Team</a></li></ul></div>
      <div><h4>Contact</h4><ul><li><a href="mailto:info@cloudmindspartners.com">info@cloudmindspartners.com</a></li><li>São Paulo · BR</li><li>Santiago · CL</li><li>Mexico City · MX</li></ul></div>
    </div>
    <div class="foot-bottom"><span>© 2026 Cloud Minds Partners</span><span>All rights reserved.</span></div>
  </footer>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</Base>
