---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

import heroTeam from '../assets/photos/hero-team.jpg';

const locale = (Astro.currentLocale ?? 'en') as 'en' | 'pt' | 'es';

// People collection lives at cmp-knowledge/people/.
// Partners are top-level files (edgard.md, gustavo.md).
// Advisors are at advisors/*.md and get id prefix "advisors/".
const everyone = await getCollection('people');
const partners = everyone.filter((p) => !p.id.includes('/'));
const advisors = everyone.filter((p) => p.id.startsWith('advisors/'));

// Photo URL resolver — photos are copied from cmp-knowledge/people/photos/
// into public/people/photos/ at build time (see deploy.yml). Schema photo
// values can be "photos/x.jpg" (partners) or "../photos/x.jpg" (advisors).
const photoUrl = (photoField: string | undefined): string | null => {
  if (!photoField) return null;
  const filename = photoField.replace(/^(\.\.\/)?photos\//, '');
  return `/people/photos/${filename}`;
};

// Deterministic ordering: Edgard before Gustavo; advisors alphabetical.
const partnerOrder: Record<string, number> = {
  'Founder & CEO': 0,
  'Head of Design & Project Management': 1,
};
partners.sort((a, b) => (partnerOrder[a.data.role] ?? 99) - (partnerOrder[b.data.role] ?? 99));
advisors.sort((a, b) => a.data.name.localeCompare(b.data.name));

// Strip leading "# Heading" + section headings, take the first 2 bullet lines
// (or paragraphs) of the markdown body. Keeps the card readable on the cream
// grid without dragging in PMP/CP3P-level detail.
const extractBio = (body: string, maxItems = 2): string => {
  const lines = body.split('\n').map((l) => l.trim());
  const bullets: string[] = [];
  for (const line of lines) {
    if (line.startsWith('- ')) {
      bullets.push(line.replace(/^-\s+/, ''));
      if (bullets.length >= maxItems) break;
    }
  }
  if (bullets.length > 0) return bullets.join(' · ');
  // Fallback: first non-heading paragraph
  const paras = body.split(/\n\n+/).filter((p) => !p.trim().startsWith('#'));
  return (paras[0] ?? '').replace(/\n/g, ' ').trim();
};

// One-line "domain" label derived from role, e.g.
// "Advisor — Energy Interconnection" → "Energy · Interconnection".
const domainLabel = (role: string): string => {
  const after = role.includes('—') ? role.split('—').slice(1).join('—') : role;
  return after.replace(/\//g, '·').replace(/\s+/g, ' ').trim();
};

// Lightweight credit line for advisors: first bullet of body.
const firstBullet = (body: string): string => {
  const line = body.split('\n').map((l) => l.trim()).find((l) => l.startsWith('- '));
  return line ? line.replace(/^-\s+/, '') : '';
};
---

<Base lang={locale}>
  <SEO
    slot="head"
    title="Team — Cloud Minds Partners"
    description="Meet the Cloud Minds Partners team — partners and senior advisors on LatAm data center site selection, grid, regulatory, and capital."
    lang={locale}
  />
  <SiteHeader />

  <!-- 1. HERO -->
  <Hero
    variant="page"
    image={heroTeam}
    eyebrow="Team"
    live
    heading="A small partnership. A wider bench."
    subheading="Two partners in São Paulo. A bench of senior advisors across Brazil — energy interconnection, telecom, and permitting."
  />

  <!-- 2. PARTNERS on cream -->
  <section class="leadership on-cream">
    <div class="section-inner">
      <div class="section-head">
        <p class="section-eyebrow">Partners</p>
        <h2>Forty years of LatAm infrastructure.</h2>
      </div>
      <div class="partner-grid">
        {partners.map((p) => {
          const src = photoUrl(p.data.photo);
          const objPos = p.data.photo_position ?? 'center center';
          return (
            <article class="partner-card">
              {src && (
                <div class="partner-avatar">
                  <img
                    src={src}
                    alt={`${p.data.name} — ${p.data.role}`}
                    class="partner-photo"
                    loading="lazy"
                    style={`object-position: ${objPos};`}
                  />
                </div>
              )}
              <h3 class="partner-name">{p.data.name}</h3>
              <div class="partner-role">{p.data.role}</div>
              <p class="partner-bio">{extractBio(p.body)}</p>
              {p.data.email && (
                <div class="partner-meta">
                  <a href={`mailto:${p.data.email}`} class="partner-contact">{p.data.email}</a>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. BENCH on navy -->
  <section class="bench">
    <div class="section-inner">
      <div class="section-head">
        <p class="section-eyebrow">Bench</p>
        <h2>Senior advisors. One call away.</h2>
      </div>
      <div class="bench-grid">
        {advisors.map((a) => {
          const src = photoUrl(a.data.photo);
          const objPos = a.data.photo_position ?? 'center center';
          return (
            <div class="bench-card">
              {src && (
                <div class="bench-avatar">
                  <img
                    src={src}
                    alt={a.data.name}
                    class="bench-photo"
                    loading="lazy"
                    style={`object-position: ${objPos};`}
                  />
                </div>
              )}
              <div class="bench-domain">{domainLabel(a.data.role)}</div>
              <h4 class="bench-name">{a.data.name}</h4>
              <p class="bench-credit">{firstBullet(a.body)}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <SiteFooter />
</Base>

<style>
  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(64px, 7vw, 112px) clamp(28px, 4vw, 64px);
  }
  .section-head {
    text-align: center;
    margin-bottom: 56px;
  }
  .section-eyebrow {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-blue-bright);
    margin: 0 0 16px;
  }
  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.6vw, 44px);
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 auto;
    max-width: 720px;
  }

  /* ——— PARTNERS on cream ——————————————————————— */
  .leadership {
    background: var(--color-cream-bg, #f5f0e8);
    color: var(--color-navy-0);
  }
  .leadership .section-head h2 {
    color: var(--color-navy-0);
  }
  .partner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .partner-card {
    border-radius: 24px;
    background: transparent;
    border: 1px solid rgba(5, 14, 29, 0.12);
    padding: 56px clamp(32px, 4vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 22px;
    align-items: center;
    text-align: center;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .partner-card:hover {
    border-color: rgba(45, 107, 228, 0.55);
    transform: translateY(-3px);
    box-shadow: 0 18px 44px rgba(45, 107, 228, 0.12);
  }
  .partner-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 8px 24px rgba(5, 14, 29, 0.10);
    flex-shrink: 0;
  }
  .partner-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .partner-name {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 600;
    letter-spacing: -0.022em;
    color: var(--color-navy-0);
    margin: 0;
    line-height: 1.1;
  }
  .partner-role {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--color-blue);
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .partner-bio {
    font-size: 17px;
    line-height: 1.55;
    color: #3d4e68;
    margin: 0;
    max-width: 42ch;
  }
  .partner-meta {
    font-family: var(--font-body);
    font-size: 14px;
    color: #677793;
    padding-top: 14px;
    border-top: 1px solid rgba(5, 14, 29, 0.08);
    width: 80%;
  }
  .partner-contact {
    color: var(--color-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .partner-contact:hover {
    opacity: 0.75;
  }

  /* ——— BENCH on navy ——————————————————————————— */
  .bench {
    background: var(--color-navy-0, #05111d);
    border-top: 1px solid var(--color-line-0);
  }
  .bench .section-head h2 {
    color: var(--color-cream-0);
  }
  .bench-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .bench-card {
    border-radius: 22px;
    padding: 44px clamp(24px, 3vw, 40px);
    background: var(--color-navy-1, #0a1a2b);
    border: 1px solid var(--color-line-1, rgba(255, 255, 255, 0.08));
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    text-align: center;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .bench-card:hover {
    background: var(--color-navy-2, #112237);
    border-color: rgba(74, 143, 231, 0.5);
    transform: translateY(-2px);
  }
  .bench-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.30);
    flex-shrink: 0;
  }
  .bench-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bench-domain {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--color-blue-bright);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .bench-name {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--color-cream-0);
    letter-spacing: -0.014em;
    margin: 0;
    line-height: 1.15;
  }
  .bench-credit {
    font-size: 15px;
    color: var(--color-cream-1);
    margin: 0;
    line-height: 1.55;
    max-width: 28ch;
  }

  /* ——— Responsive ——————————————————————————— */
  @media (max-width: 1100px) {
    .bench-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 880px) {
    .partner-grid,
    .bench-grid {
      grid-template-columns: 1fr;
    }
    .partner-card {
      padding: 40px 28px;
    }
  }
</style>
