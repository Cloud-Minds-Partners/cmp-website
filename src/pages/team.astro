---
import V4Layout from "../components/v4/V4Layout.astro";
import { getCollection, render } from "astro:content";

const everyone = await getCollection("people");
const partners = everyone.filter((p) => !p.id.includes("/"));
const advisors = everyone.filter((p) => p.id.includes("/") && p.id.startsWith("advisors/"));

const photoSrc = (photoField: string | undefined) => {
  if (!photoField) return null;
  const filename = photoField.replace(/^(\.\.\/)?photos\//, "");
  return `/people/photos/${filename}`;
};

const partnerOrder: Record<string, number> = {
  "Founder & CEO": 0,
  "Head of Design & Project Management": 1,
};
partners.sort((a, b) => (partnerOrder[a.data.role] ?? 99) - (partnerOrder[b.data.role] ?? 99));
advisors.sort((a, b) => a.data.name.localeCompare(b.data.name));

const renderedPartners = await Promise.all(
  partners.map(async (p) => {
    const { Content } = await render(p);
    return { ...p, Content };
  }),
);
const renderedAdvisors = await Promise.all(
  advisors.map(async (a) => {
    const { Content } = await render(a);
    return { ...a, Content };
  }),
);
---

<V4Layout title="Team — Cloud Minds Partners" description="Partners and advisors at Cloud Minds Partners — data center advisory and development for Latin America." active="team">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero">
    <div class="v4-page-hero-inner">
      <span class="v4-eyebrow">Team</span>
      <h1 class="v4-display-xl" style="max-width:1000px;">
        A small partnership.<br/>
        A <em class="v4-italic-rust">wider bench</em>.
      </h1>
      <p class="v4-lede">
        Cloud Minds Partners is led by two partners in São Paulo, backed by a bench of
        technical advisors in energy interconnection, telecom infrastructure, and permitting.
      </p>
    </div>
  </section>

  <!-- ═══ PARTNERS ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <span class="v4-eyebrow v4-eyebrow-light">Partners</span>
      <h2 class="v4-display-lg" style="margin-bottom:48px;">Leadership.</h2>
      <div class="v4-card-grid-2">
        {renderedPartners.map((p) => {
          const src = photoSrc(p.data.photo);
          const objPos = p.data.photo_position ?? "center center";
          return (
            <article class="v4-card v4-person-card">
              {src && (
                <img src={src} alt={p.data.name} class="v4-person-photo"
                  style={`object-position: ${objPos};`} />
              )}
              <div class="v4-card-num">{p.data.role.toUpperCase()}</div>
              <h3 class="v4-card-name" style="font-size:28px;">{p.data.name}</h3>
              <div class="v4-person-bio">
                <p.Content />
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══ ADVISORS ═══ -->
  <section class="v4-section v4-section-dark">
    <div class="v4-section-inner">
      <span class="v4-eyebrow">Advisors</span>
      <h2 class="v4-display-lg">Domain bench.</h2>
      <p class="v4-lede" style="margin-bottom:56px;">
        Our advisors work on engagement-specific mandates across energy interconnection,
        telecom and connectivity infrastructure, and permitting.
      </p>
      <div class="v4-card-grid v4-card-grid-dark">
        {renderedAdvisors.map((a) => {
          const src = photoSrc(a.data.photo);
          const objPos = a.data.photo_position ?? "center center";
          return (
            <article class="v4-card v4-card-dark v4-person-card">
              {src && (
                <img src={src} alt={a.data.name} class="v4-person-photo"
                  style={`width:96px; height:96px; object-position: ${objPos}; border-color: var(--v4-rule-dark-strong);`} />
              )}
              <div class="v4-card-num">{a.data.role.toUpperCase()}</div>
              <h3 class="v4-card-name" style="font-size:20px;">{a.data.name}</h3>
              <div class="v4-person-bio v4-person-bio-dark">
                <a.Content />
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</V4Layout>

<style>
  .v4-person-card { padding-top: 48px !important; }
  .v4-person-photo {
    width: 128px; height: 128px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-rule);
    margin-bottom: 24px;
  }
  .v4-person-bio {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink-muted);
    margin-top: 4px;
  }
  .v4-person-bio :global(p) { margin: 0 0 10px; }
  .v4-person-bio :global(h1) { display: none; }
  .v4-person-bio :global(ul) { margin: 8px 0; padding-left: 18px; }
  .v4-person-bio :global(li) { margin: 2px 0; }
  .v4-person-bio-dark { color: var(--v4-text-on-dark-muted); }
</style>
