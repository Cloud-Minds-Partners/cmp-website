---
import Base from "../../../layouts/Base.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import Section from "../../../components/Section.astro";
import { getCollection } from "astro:content";

const radar = (await getCollection("radar", (r) => r.data.published)).sort((a, b) => {
  const aStart = a.data.period_start?.valueOf() ?? 0;
  const bStart = b.data.period_start?.valueOf() ?? 0;
  return bStart - aStart;
});

const fmt = (d: Date | undefined) =>
  d ? d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) : "";
---

<Base title="Innovation Radar — Cloud Minds Partners">
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos" },
      { href: "/intelligence/radar", label: "Innovation Radar", active: true },
      { href: "/intelligence/regwatch", label: "Regulatory Watch" },
    ]}
  />

  <main>
    <section class="pt-20 pb-12 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-4">Intelligence · Radar</div>
        <h1 class="display text-4xl md:text-5xl max-w-3xl">Innovation Radar.</h1>
        <p class="lede mt-5 max-w-2xl">
          Weekly scan of infrastructure, AI, competitive, and regulatory
          signals worth tracking for LatAm data center operators.
        </p>
      </div>
    </section>

    <Section compact>
      {radar.length === 0 && (
        <p class="text-[var(--color-ink-muted)] italic">No radar entries published yet.</p>
      )}

      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {radar.map((entry) => (
          <a href={`/intelligence/radar/${entry.data.week ?? entry.id}`} class="block py-8 no-underline hover:bg-[var(--color-surface)] -mx-6 px-6 transition-colors">
            <div class="grid md:grid-cols-12 gap-6">
              <div class="md:col-span-3">
                <div class="caption text-[var(--color-navy)]">Week {entry.data.week ?? entry.id}</div>
                {entry.data.period_start && entry.data.period_end && (
                  <div class="caption mt-1">{fmt(entry.data.period_start)} — {fmt(entry.data.period_end)}</div>
                )}
              </div>
              <div class="md:col-span-9">
                <h2 class="display text-xl">Week {entry.data.week ?? entry.id}</h2>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
