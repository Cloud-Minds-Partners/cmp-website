---
import Base from "../../../layouts/Base.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import Section from "../../../components/Section.astro";
import { getCollection } from "astro:content";

const memos = (await getCollection("memos", (m) => m.data.publish)).sort(
  (a, b) => b.data.created.valueOf() - a.data.created.valueOf(),
);

const countryName: Record<string, string> = {
  BR: "Brazil", MX: "Mexico", CL: "Chile", AR: "Argentina",
  CO: "Colombia", PE: "Peru", UY: "Uruguay",
};

const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short" });
---

<Base title="Technical Memos — Cloud Minds Partners">
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos", active: true },
      { href: "/intelligence/radar", label: "Innovation Radar" },
      { href: "/intelligence/regwatch", label: "Regulatory Watch" },
    ]}
  />

  <main>
    <section class="pt-20 pb-12 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-4">Intelligence · Memos</div>
        <h1 class="display text-4xl md:text-5xl max-w-3xl">Technical Memos.</h1>
        <p class="lede mt-5 max-w-2xl">
          Five-page briefs on regulatory, fiscal, and market developments in
          Latin American data center markets.
        </p>
      </div>
    </section>

    <Section compact>
      {memos.length === 0 && (
        <p class="text-[var(--color-ink-muted)] italic">No memos published yet.</p>
      )}

      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {memos.map((memo) => (
          <a href={`/intelligence/memos/${memo.data.slug}`} class="block py-8 no-underline hover:bg-[var(--color-surface)] -mx-6 px-6 transition-colors">
            <div class="grid md:grid-cols-12 gap-6">
              <div class="md:col-span-3">
                <div class="caption text-[var(--color-navy)]">
                  {countryName[memo.data.jurisdiction.country] ?? memo.data.jurisdiction.country} · {memo.data.jurisdiction.scope}
                </div>
                <div class="caption mt-1">{fmt(memo.data.created)}</div>
              </div>
              <div class="md:col-span-9">
                <h2 class="display text-xl md:text-2xl mb-2">{memo.data.title}</h2>
                {memo.data.sources_count !== undefined && (
                  <p class="text-sm text-[var(--color-ink-muted)]">
                    {memo.data.sources_count} primary sources · {memo.data.word_count} words
                  </p>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
