---
import V4Layout from "../../components/v4/V4Layout.astro";
import TierNetwork from "../../components/v4/TierNetwork.astro";
import { getCollection } from "astro:content";

const memos = (await getCollection("memos", (m) => m.data.publish)).length;
const radar = (await getCollection("radar", (r) => r.data.published)).length;
const regwatch = (await getCollection("regwatch", (r) => r.data.published)).length;

const streams = [
  {
    href: "/intelligence/memos",
    eyebrow: "Long-form",
    count: `${memos} published`,
    title: "Technical Memos",
    body: "Five-page briefs on regulatory, fiscal, and market developments. Minimum three primary sources per memo, audited before publication.",
    cta: "Browse memos",
  },
  {
    href: "/intelligence/radar",
    eyebrow: "Weekly",
    count: `${radar} entries`,
    title: "Innovation Radar",
    body: "Weekly scan of infrastructure, AI, competitive, and regulatory signals. Candidates graduate to memos, client conversations, or platform updates.",
    cta: "Browse radar",
  },
  {
    href: "/intelligence/regwatch",
    eyebrow: "Monthly",
    count: `${regwatch} digests`,
    title: "Regulatory Watch",
    body: "Monthly digest of regulatory, legal, and fiscal changes across seven LatAm jurisdictions. Every change cites a primary source downloaded to our intelligence corpus.",
    cta: "Browse watch",
  },
];
---

<V4Layout title="Intelligence — Cloud Minds Partners" description="Published research on Latin American data center markets — memos, radar, regulatory watch." active="intelligence">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero has-visual">
    <div class="v4-page-hero-inner">
      <div>
        <span class="v4-eyebrow">03 / Intelligence</span>
        <h1 class="v4-display-xl">
          Published research on <em class="v4-italic-rust">Latin American</em> data center markets.
        </h1>
        <p class="v4-lede">
          Three streams. Each grounded in primary sources. Each peer-reviewed
          before release. No hot takes, no press-release reshuffling.
        </p>
        <div class="v4-btn-row">
          <a href="/intelligence/memos" class="v4-btn v4-btn-primary">Read memos →</a>
          <a href="/newsletter" class="v4-btn v4-btn-secondary">Weekly Pulse</a>
        </div>
      </div>
      <div class="v4-tier-visual"><TierNetwork /></div>
    </div>
  </section>

  <!-- ═══ STREAMS ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <span class="v4-eyebrow v4-eyebrow-light">Streams</span>
      <h2 class="v4-display-lg" style="margin-bottom:16px;">Three cadences. One method.</h2>
      <p class="v4-lede v4-lede-light" style="margin-bottom:56px;">
        Different tempos for different signal-to-noise. All audited.
      </p>
      <div class="v4-card-grid">
        {streams.map((s, i) => (
          <a href={s.href} class="v4-card">
            <div class="v4-card-num">{s.eyebrow.toUpperCase()} · {s.count}</div>
            <h3 class="v4-card-name">{s.title}</h3>
            <p class="v4-card-desc">{s.body}</p>
            <span class="v4-card-arrow">{s.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ METHOD ═══ -->
  <section class="v4-section v4-section-dark">
    <div class="v4-section-narrow">
      <span class="v4-eyebrow">Method</span>
      <h2 class="v4-display-lg">Chain of Truth.</h2>
      <p class="v4-lede" style="font-size:20px; max-width:760px;">
        Every claim in a CMP publication traces to a primary source we have
        downloaded and archived. Citations are enforced by an audit gate
        that blocks publication when references don't resolve to a
        verifiable document in our intelligence repository.
      </p>
      <p class="v4-lede" style="margin-top:20px; max-width:760px;">
        This is why memos are capped at five pages: the bar is density of
        cited fact, not word count.
      </p>
    </div>
  </section>

  <!-- ═══ BIG CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Subscribe to the<br/>
        <em class="v4-italic-rust">DC Weekly Pulse</em>
      </h2>
      <p class="v4-big-cta-body">
        Three to four LatAm-relevant stories every week. WebFetched primary
        sources, audited before send. No filler.
      </p>
      <a href="/newsletter" class="v4-btn v4-btn-primary v4-btn-large">Subscribe →</a>
    </div>
  </section>
</V4Layout>
