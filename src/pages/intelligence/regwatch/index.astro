---
import Base from "../../../layouts/Base.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import Section from "../../../components/Section.astro";
import { getCollection } from "astro:content";

const regwatch = (await getCollection("regwatch", (r) => r.data.published)).sort((a, b) =>
  (b.data.month ?? b.id).localeCompare(a.data.month ?? a.id),
);

const fmtMonth = (m: string) => {
  const [y, mo] = m.split("-").map(Number);
  if (!y || !mo) return m;
  return new Date(y, mo - 1, 1).toLocaleDateString("en-US", { year: "numeric", month: "long" });
};
---

<Base title="Regulatory Watch — Cloud Minds Partners">
  <SiteHeader
    active="intelligence"
    subnav={[
      { href: "/intelligence", label: "Overview" },
      { href: "/intelligence/memos", label: "Technical Memos" },
      { href: "/intelligence/radar", label: "Innovation Radar" },
      { href: "/intelligence/regwatch", label: "Regulatory Watch", active: true },
    ]}
  />

  <main>
    <section class="pt-20 pb-12 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-4">Intelligence · Regulatory</div>
        <h1 class="display text-4xl md:text-5xl max-w-3xl">Regulatory Watch.</h1>
        <p class="lede mt-5 max-w-2xl">
          Monthly digest of regulatory, legal, and fiscal changes across
          seven Latin American jurisdictions.
        </p>
      </div>
    </section>

    <Section compact>
      {regwatch.length === 0 && (
        <p class="text-[var(--color-ink-muted)] italic">No digests published yet.</p>
      )}

      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {regwatch.map((entry) => (
          <a href={`/intelligence/regwatch/${entry.data.month ?? entry.id}`} class="block py-8 no-underline hover:bg-[var(--color-surface)] -mx-6 px-6 transition-colors">
            <div class="grid md:grid-cols-12 gap-6">
              <div class="md:col-span-3">
                <div class="caption text-[var(--color-navy)]">{fmtMonth(entry.data.month ?? entry.id)}</div>
              </div>
              <div class="md:col-span-9">
                <h2 class="display text-xl">{fmtMonth(entry.data.month ?? entry.id)}</h2>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
