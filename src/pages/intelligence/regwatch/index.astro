---
import V4Layout from "../../../components/v4/V4Layout.astro";
import { getCollection } from "astro:content";

const regwatch = (await getCollection("regwatch", (r) => r.data.published)).sort((a, b) =>
  (b.data.month ?? b.id).localeCompare(a.data.month ?? a.id),
);

const fmtMonth = (m: string) => {
  const [y, mo] = m.split("-").map(Number);
  if (!y || !mo) return m;
  return new Date(y, mo - 1, 1).toLocaleDateString("en-US", { year: "numeric", month: "long" });
};
---

<V4Layout title="Regulatory Watch — Cloud Minds Partners" description="Monthly digest of regulatory, legal, and fiscal changes across seven Latin American jurisdictions." active="intelligence">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero">
    <div class="v4-page-hero-inner">
      <nav style="margin-bottom:20px;">
        <a href="/intelligence" class="v4-back-link">← Intelligence</a>
      </nav>
      <span class="v4-eyebrow">Monthly · Regulatory Watch</span>
      <h1 class="v4-display-xl" style="max-width:900px;">
        Seven jurisdictions. <em class="v4-italic-rust">Every change cited.</em>
      </h1>
      <p class="v4-lede">
        Monthly digest of regulatory, legal, and fiscal changes across Brazil,
        Chile, Mexico, Argentina, Colombia, Peru, and Uruguay. Every change cites
        a primary source downloaded to our intelligence corpus.
      </p>
    </div>
  </section>

  <!-- ═══ REGWATCH LIST ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      {regwatch.length === 0 ? (
        <p style="font-family:var(--font-body); font-size:15px; color:var(--color-ink-muted); font-style:italic;">
          No digests published yet.
        </p>
      ) : (
        <div class="v4-memo-list">
          {regwatch.map((entry) => (
            <a href={`/intelligence/regwatch/${entry.data.month ?? entry.id}`} class="v4-memo-row">
              <div class="v4-memo-meta">
                <span class="v4-memo-country">{fmtMonth(entry.data.month ?? entry.id)}</span>
              </div>
              <div class="v4-memo-body">
                <h3 class="v4-memo-title">Regulatory Watch — {fmtMonth(entry.data.month ?? entry.id)}</h3>
              </div>
              <span class="v4-card-arrow">Read →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</V4Layout>

<style>
  .v4-back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-ink-quiet);
    text-decoration: none;
  }
  .v4-back-link:hover { color: var(--color-rust); }

  .v4-memo-list { border-top: 1px solid var(--color-rule); }

  .v4-memo-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 28px 24px;
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    margin: 0 -24px;
  }
  .v4-memo-row:hover { background: var(--color-surface); }

  .v4-memo-meta { display: flex; flex-direction: column; gap: 6px; }
  .v4-memo-country {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-navy);
  }
  .v4-memo-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.3;
  }
</style>
