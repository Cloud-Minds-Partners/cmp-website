---
import Base from '../../../layouts/Base.astro';
import SEO from '../../../components/SEO.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import LocaleBanner from '../../../components/LocaleBanner.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const locale = (Astro.currentLocale ?? 'en') as 'en' | 'pt' | 'es';
const t = useTranslations(locale);

const allEntries = await getCollection('regwatch', (r) => r.data.published);
const localeEntries = allEntries.filter((r) => r.data.language === locale);
const entries = (localeEntries.length > 0 ? localeEntries : allEntries)
  .sort((a, b) => (b.data.month ?? b.id).localeCompare(a.data.month ?? a.id));
const showFallbackBanner = localeEntries.length === 0 && locale !== 'en';

const fmtMonth = (m: string): string => {
  const [y, mo] = m.split('-').map(Number);
  if (!y || !mo) return m;
  return new Date(y, mo - 1, 1).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
};
---

<Base lang={locale}>
  <SEO
    slot="head"
    title="Regulatory Watch — Cloud Minds Partners"
    description="Monthly regulatory digest for LatAm data center markets — permitting, policy, and fiscal changes."
    lang={locale}
  />
  <SiteHeader subnav={[
    { href: '/intelligence', label: 'Overview' },
    { href: '/intelligence/memos', label: 'Technical Memos' },
    { href: '/intelligence/radar', label: 'Innovation Radar' },
    { href: '/intelligence/regwatch', label: 'Regulatory Watch', active: true },
  ]} />

  {showFallbackBanner && <LocaleBanner />}

  <main class="collection-main">
    <div class="collection-header">
      <p class="collection-eyebrow">Intelligence</p>
      <h1>Regulatory Watch</h1>
      <p class="collection-lede">Monthly digest of regulatory changes affecting LatAm data center investment — across seven jurisdictions.</p>
    </div>

    {entries.length === 0 ? (
      <div class="empty-state">
        <p>{t('common.empty-regwatch')}</p>
      </div>
    ) : (
      <div class="regwatch-list">
        {entries.map((entry, i) => (
          <a href={`/intelligence/regwatch/${entry.data.month ?? entry.id}`} class="regwatch-row">
            <span class="regwatch-num">{String(i + 1).padStart(3, '0')}</span>
            <span class="regwatch-month">{fmtMonth(entry.data.month ?? entry.id)}</span>
            <span class="regwatch-id">{entry.data.month ?? entry.id}</span>
            <span class="regwatch-author">{entry.data.author}</span>
          </a>
        ))}
      </div>
    )}
  </main>

  <SiteFooter />
</Base>

<style>
  .collection-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(64px, 8vw, 120px) clamp(28px, 4vw, 64px) clamp(96px, 14vh, 160px);
  }

  .collection-header {
    margin-bottom: 64px;
    border-bottom: 1px solid rgba(250, 251, 253, 0.07);
    padding-bottom: 48px;
  }

  .collection-eyebrow {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-blue-bright, #4a8fe7);
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .collection-eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .collection-header h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 600;
    color: var(--color-cream-0);
    margin: 0 0 16px;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .collection-lede {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-cream-2);
    margin: 0;
    max-width: 560px;
  }

  .empty-state {
    border: 1px dashed rgba(250, 251, 253, 0.18);
    border-radius: 12px;
    padding: 48px 32px;
    text-align: center;
    color: var(--color-cream-2);
    font-size: 15px;
    max-width: 540px;
    margin: 0 auto;
  }

  .regwatch-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(250, 251, 253, 0.07);
  }

  .regwatch-row {
    display: grid;
    grid-template-columns: 72px 240px 1fr 140px;
    gap: clamp(16px, 2.6vw, 36px);
    padding: 22px 0;
    border-bottom: 1px solid rgba(250, 251, 253, 0.07);
    text-decoration: none;
    color: var(--color-cream-1);
    align-items: baseline;
    transition: background 0.15s, color 0.15s;
  }

  .regwatch-row:hover {
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-cream-0);
  }

  .regwatch-num {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-cream-0);
    letter-spacing: -0.01em;
  }

  .regwatch-month {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-cream-0);
  }

  .regwatch-id {
    font-size: 13px;
    color: var(--color-cream-2);
  }

  .regwatch-author {
    font-size: 13px;
    color: var(--color-cream-2);
    justify-self: end;
  }

  @media (max-width: 880px) {
    .regwatch-row {
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 18px 0;
    }

    .regwatch-author {
      justify-self: start;
    }
  }
</style>
