---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Section from "../components/Section.astro";
import WeeklyPulseSection from "../components/WeeklyPulseSection.astro";
import NewsletterSubscribe from "../components/NewsletterSubscribe.astro";
import NewsletterArchive from "../components/NewsletterArchive.astro";

const platforms = [
  { name: "Site Selection Tool", desc: "Multi-criteria scoring across 76+ cities in Brazil, Chile, and Mexico.", url: "https://dcplatformcmp.web.app", showHost: true },
  { name: "Land Intel", desc: "Land price intelligence across 25 active markets.", url: "https://land-price-dashboard.web.app", showHost: true },
  { name: "TestFit Pro", desc: "Data center test-fit with 30+ reference presets.", url: "https://dc-testfit-pro.web.app", showHost: true },
  { name: "DC Insights", desc: "Weekly LatAm data center newsletter.", url: "https://dcinsights.web.app", showHost: true },
  { name: "Project Management Dashboard", desc: "Client project tracking, milestones, and deliverables across active engagements.", url: null, showHost: false },
  { name: "Financial Model", desc: "DC financial modeling and scenario analysis.", url: null, showHost: false },
];
---

<Base title="Cloud Minds Partners — Data Center Advisory for Latin America">
  <SiteHeader active="home" />

  <main>
    <!-- ——— Hero ————————————————————————————————— -->
    <section class="pt-20 md:pt-28 pb-20 md:pb-28 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-6">Cloud Minds Partners · Est. 2024</div>
        <h1 class="display-lg max-w-4xl text-[var(--color-ink)]">
          Data center projects in Latin America,
          <span class="text-[var(--color-navy)] italic">built on research.</span>
        </h1>
        <p class="lede mt-8 max-w-2xl">
          We work with hyperscalers, colocators, developers, and funds on the
          parts of the project that don't fit neatly into a spreadsheet —
          site selection, feasibility, regulatory path, and market context.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
          <a href="/advisory" class="no-underline text-[var(--color-ink)] font-semibold">Advisory →</a>
          <a href="/development" class="no-underline text-[var(--color-ink)] font-semibold">Development →</a>
          <a href="/intelligence" class="no-underline text-[var(--color-ink)] font-semibold">Intelligence →</a>
        </div>
      </div>
    </section>

    <!-- ——— 3 Pillars ———————————————————————————— -->
    <Section eyebrow="What we do" title="Three practices, one thesis.">
      <div class="grid md:grid-cols-3 gap-0 md:gap-px bg-[var(--color-rule)]">
        <a href="/advisory" class="bg-[var(--color-canvas)] p-10 no-underline block group hover:bg-[var(--color-surface)]">
          <div class="caption mb-4">01 / Advisory</div>
          <h3 class="display text-2xl mb-4 text-[var(--color-ink)]">Advisory</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed">
            Site selection, feasibility studies, and market intelligence
            tailored to the regulatory and infrastructure realities of
            Brazil, Chile, Mexico, and the wider region.
          </p>
          <span class="mt-6 inline-block text-[var(--color-navy)] text-sm font-semibold group-hover:text-[var(--color-accent)]">Read more →</span>
        </a>
        <a href="/development" class="bg-[var(--color-canvas)] p-10 no-underline block group hover:bg-[var(--color-surface)]">
          <div class="caption mb-4">02 / Project development</div>
          <h3 class="display text-2xl mb-4 text-[var(--color-ink)]">Development</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed">
            Co-development, technical due diligence, and financial modeling
            for greenfield and brownfield data center projects — from
            pre-site through commissioning.
          </p>
          <span class="mt-6 inline-block text-[var(--color-navy)] text-sm font-semibold group-hover:text-[var(--color-accent)]">Read more →</span>
        </a>
        <a href="/intelligence" class="bg-[var(--color-canvas)] p-10 no-underline block group hover:bg-[var(--color-surface)]">
          <div class="caption mb-4">03 / Intelligence</div>
          <h3 class="display text-2xl mb-4 text-[var(--color-ink)]">Intelligence</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed">
            Technical memos, weekly innovation radar, and monthly regulatory
            digests — plus a set of proprietary platforms used in our own
            engagements and by clients.
          </p>
          <span class="mt-6 inline-block text-[var(--color-navy)] text-sm font-semibold group-hover:text-[var(--color-accent)]">Read more →</span>
        </a>
      </div>
    </Section>

    <!-- ——— Platforms strip ————————————————————————— -->
    <Section
      eyebrow="Platforms"
      title="Purpose-built tools."
      lede="We productize the parts of our work that survive across engagements. Used internally by our team and available to clients under engagement."
      tone="alt"
    >
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-[var(--color-rule)]">
        {platforms.map((p) => {
          const inner = (
            <>
              <h3 class="display text-lg text-[var(--color-ink)] mb-2">{p.name}</h3>
              <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed">{p.desc}</p>
              {p.url && p.showHost && (
                <span class="mt-4 inline-block caption text-[var(--color-navy)]">{new URL(p.url).host}</span>
              )}
            </>
          );
          return p.url ? (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="bg-[var(--color-surface)] p-7 no-underline block hover:bg-[var(--color-surface-alt)] transition-colors"
            >
              {inner}
            </a>
          ) : (
            <div class="bg-[var(--color-surface)] p-7">
              {inner}
            </div>
          );
        })}
      </div>
    </Section>

    <!-- ——— Weekly Pulse ———————————————————————————— -->
    <Section>
      <WeeklyPulseSection />
    </Section>

    <!-- ——— Newsletter ——————————————————————————————— -->
    <Section tone="alt">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <NewsletterSubscribe />
        </div>
        <div class="md:col-span-7">
          <NewsletterArchive />
        </div>
      </div>
    </Section>

    <!-- ——— Contact ————————————————————————————— -->
    <Section tone="ink" compact>
      <div class="grid md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8">
          <div class="eyebrow text-[color:color-mix(in_srgb,var(--color-canvas)_60%,transparent)] mb-4">Engagement</div>
          <h2 class="display text-3xl md:text-4xl max-w-2xl text-[var(--color-canvas)]">
            Exploring a site, a feasibility question, or a regulatory path in Latin America?
          </h2>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a
            href="mailto:info@cloudmindspartners.com"
            class="inline-block no-underline text-[var(--color-canvas)] border border-[var(--color-canvas)] px-5 py-2.5 hover:bg-[var(--color-canvas)] hover:text-[var(--color-ink)] transition-colors"
          >
            info@cloudmindspartners.com
          </a>
        </div>
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
