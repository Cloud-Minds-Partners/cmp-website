---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
---

<Base lang="en">
  <SEO
    slot="head"
    title="Cloud Minds Partners — Data Center Intelligence for Latin America"
    description="Advisory, development, and data center intelligence — applied across Brazil, Chile, and Mexico."
    image="/og/home.png"
  />

  <style slot="head" is:global>
    /* HOME-specific (literal port of mock-26/index.html) */
    .home-hero {
      position: relative;
      min-height: calc(100vh - 72px);
      display: flex; align-items: center;
      padding: 80px 0;
      isolation: isolate; overflow: hidden;
    }
    .home-hero-slides {
      position: absolute; inset: 0; z-index: -4;
      background: var(--navy-0);
    }
    .home-hero-slide {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
      opacity: 0;
      transform: scale(1.04);
      animation: slideShow 24s infinite cubic-bezier(.4,0,.2,1);
      filter: saturate(1.18) contrast(1.06) brightness(1.04);
      will-change: opacity, transform;
    }
    .home-hero-slide:nth-child(1) {
      background-image: url("/photos/hero-sp-marginal.jpg");
      animation-delay: 0s;
    }
    .home-hero-slide:nth-child(2) {
      background-image: url("/photos/hero-santiago.jpg");
      animation-delay: 8s;
    }
    .home-hero-slide:nth-child(3) {
      background-image: url("/photos/hero-cdmx.jpg");
      animation-delay: 16s;
      filter: saturate(1.18) contrast(1.06) brightness(0.95);
    }
    @keyframes slideShow {
      0%   { opacity: 0; transform: scale(1.0); }
      4%   { opacity: 1; }
      29%  { opacity: 1; }
      34%  { opacity: 0; transform: scale(1.08); }
      100% { opacity: 0; transform: scale(1.08); }
    }
    .home-hero-overlay {
      position: absolute; inset: 0; z-index: -3;
      background:
        radial-gradient(ellipse 50% 40% at 0% 70%, rgba(74, 143, 231, 0.32), transparent 60%),
        linear-gradient(180deg, rgba(5,14,29,0.05) 0%, rgba(5,14,29,0.22) 50%, rgba(5,14,29,0.78) 100%),
        linear-gradient(90deg, rgba(5,14,29,0.52) 0%, rgba(5,14,29,0.10) 55%, rgba(5,14,29,0.0) 100%);
    }
    .home-hero-grid {
      position: absolute; inset: 0; z-index: -2; pointer-events: none;
      background-image:
        linear-gradient(rgba(74,143,231,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(74,143,231,0.04) 1px, transparent 1px);
      background-size: 88px 88px;
      mask-image: linear-gradient(180deg, transparent, black 25%, black 70%, transparent);
    }
    .home-hero-content { position: relative; z-index: 1; max-width: 820px; margin-left: 0; }
    .home-hero .wrap {
      max-width: none; width: 100%; margin: 0;
      padding-left: clamp(32px, 5vw, 96px);
      padding-right: clamp(32px, 5vw, 96px);
    }
    .home-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(36px, 4.6vw, 60px);
      line-height: 1.08;
      letter-spacing: var(--track-display);
      font-weight: 600;
      margin: 0;
      max-width: 820px;
      color: var(--cream-0);
    }
    .home-hero h1 .blue { color: var(--blue-bright); }
    .home-hero p {
      margin: 24px 0 0;
      max-width: 540px;
      font-size: 17px; line-height: 1.6;
      color: var(--cream-1);
    }
    .home-actions {
      margin-top: 36px;
      display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
    }
    .home-hero-progress {
      position: absolute; bottom: 28px; right: clamp(28px, 4vw, 64px); z-index: 1;
      display: flex; gap: 4px;
    }
    .home-hero-progress-track {
      width: 56px; height: 1px; background: rgba(245, 241, 232, 0.12); position: relative; overflow: hidden;
    }
    .home-hero-progress-fill {
      position: absolute; inset: 0; background: var(--blue-bright);
      transform: scaleX(0); transform-origin: left;
      animation: progressFill 8s linear infinite;
    }
    .home-hero-progress-track:nth-child(2) .home-hero-progress-fill { animation-delay: -16s; }
    .home-hero-progress-track:nth-child(3) .home-hero-progress-fill { animation-delay: -8s; }
    @keyframes progressFill { 0% { transform: scaleX(0); } 100% { transform: scaleX(1); } }

    .stats { background: var(--black-1); border-top: 1px solid var(--line-0); border-bottom: 1px solid var(--line-0); }
    .stats::before {
      content: ""; display: block; height: 1px;
      background: linear-gradient(90deg, transparent, var(--blue-bright), transparent);
      opacity: 0.5; margin-bottom: -1px;
    }
    .stats-inner {
      display: grid; grid-template-columns: repeat(4, 1fr);
      max-width: var(--max-w); margin: 0 auto; padding: 0 var(--gutter);
    }
    .stat { padding: 60px 32px 60px 0; border-right: 1px solid var(--line-0); }
    .stat:last-child { border-right: 0; padding-right: 0; }
    .stat-num {
      font-family: var(--font-display);
      font-size: clamp(40px, 4.6vw, 64px);
      line-height: 0.95; font-weight: 600;
      letter-spacing: var(--track-tight);
      color: var(--cream-0);
      font-feature-settings: "tnum", "lnum";
      display: flex; align-items: baseline; gap: 6px;
    }
    .stat-num .unit { font-family: var(--font-body); font-size: 14px; color: var(--cream-2); font-weight: 500; letter-spacing: 0; margin-left: 6px; }
    .stat-label { margin-top: 14px; font-size: 13.5px; color: var(--cream-1); line-height: 1.5; max-width: 240px; }

    .capabilities { padding: clamp(96px, 14vh, 160px) 0; background: var(--cream-bg); color: var(--navy-0); }
    .capabilities .cap-grid {
      margin-top: 56px;
      grid-template-columns: repeat(2, 1fr);
    }

    .insight {
      background: var(--black);
      padding: clamp(96px, 14vh, 160px) 0;
      border-top: 1px solid var(--line-0);
    }
    .insight-inner {
      display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(48px, 6vw, 96px);
      max-width: var(--max-w); margin: 0 auto; padding: 0 var(--gutter);
      align-items: center;
    }
    .insight-img {
      aspect-ratio: 5 / 4;
      position: relative; overflow: hidden;
      border: 1px solid var(--line-1);
    }
    .insight-img-bg {
      position: absolute; inset: 0;
      background: url("/photos/memo-home-grid-headroom.jpg") center / cover no-repeat;
      animation: insKen 22s ease-in-out infinite alternate;
      filter: saturate(1.05) contrast(1.05);
    }
    @keyframes insKen { 0% { transform: scale(1) translate(0,0); } 100% { transform: scale(1.1) translate(-2%,-1.5%); } }
    .insight-img::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(180deg, transparent 40%, rgba(5, 14, 29, 0.65) 100%);
      z-index: 1;
    }
    .insight-tag {
      position: absolute; top: 22px; left: 22px; z-index: 2;
      font-family: var(--font-body); font-size: 12.5px;
      letter-spacing: 0; text-transform: none;
      color: var(--cream-0);
      background: rgba(5, 14, 29, 0.78); backdrop-filter: blur(10px);
      padding: 7px 11px; border: 1px solid var(--blue-bright);
    }
    .insight-tag::before {
      content: ""; display: inline-block; width: 6px; height: 6px;
      border-radius: 50%; background: var(--blue-bright); margin-right: 8px;
      vertical-align: middle;
      box-shadow: 0 0 6px var(--blue-bright);
      animation: pulse 2.2s ease-out infinite;
    }
    .insight-stat-overlay {
      position: absolute; bottom: 22px; left: 22px; right: 22px; z-index: 2;
      background: rgba(5, 14, 29, 0.82); backdrop-filter: blur(12px);
      border: 1px solid var(--line-1);
      padding: 18px 22px;
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px;
    }
    .insight-stat-overlay > span {
      display: flex; flex-direction: column; gap: 6px;
      font-family: var(--font-body); font-size: 12px;
      letter-spacing: 0; text-transform: none;
      color: var(--cream-3);
    }
    .insight-stat-overlay strong {
      font-family: var(--font-display);
      color: var(--cream-0); font-weight: 600;
      letter-spacing: var(--track-tight); font-size: 20px;
    }
    .insight-stat-overlay strong.blue { color: var(--blue-bright); }
    .insight h3 {
      font-family: var(--font-display);
      font-size: clamp(26px, 3.2vw, 40px); line-height: 1.1;
      letter-spacing: var(--track-display); font-weight: 600;
      margin: 0; color: var(--cream-0);
      max-width: 580px;
    }
    .insight h3 .blue { color: var(--blue-bright); }
    .insight-inner > div > p { margin: 24px 0 0; font-size: 16px; line-height: 1.65; color: var(--cream-1); max-width: 500px; }
    .insight-meta {
      margin-top: 36px; display: flex; gap: 32px;
      padding-top: 24px; border-top: 1px solid var(--line-0);
    }
    .insight-meta span { display: flex; flex-direction: column; gap: 6px; font-family: var(--font-body); font-size: 12.5px; letter-spacing: 0; text-transform: none; color: var(--cream-3); }
    .insight-meta strong { color: var(--cream-0); font-weight: 600; letter-spacing: 0; text-transform: none; font-family: var(--font-body); font-size: 14.5px; }
    .insight-cta {
      margin-top: 32px;
      display: inline-flex; align-items: center; gap: 12px;
      font-size: 14px; color: var(--blue-bright); font-weight: 600;
      padding-bottom: 4px; border-bottom: 1px solid var(--blue-bright);
      transition: gap var(--t-fast), color var(--t-fast);
    }
    .insight-cta:hover { gap: 18px; color: var(--cream-0); }

    @media (max-width: 1100px) {
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .stat { padding: 36px 24px 36px 0; }
      .stat:nth-child(2) { padding-right: 0; border-right: 0; }
      .stat:nth-child(3) { border-top: 1px solid var(--line-0); }
      .stat:nth-child(4) { border-top: 1px solid var(--line-0); border-right: 0; padding-right: 0; }
    }
    @media (max-width: 880px) {
      .stats-inner, .cap-grid, .insight-inner { grid-template-columns: 1fr; }
      .insight-img { aspect-ratio: 16 / 10; }
    }
  </style>

  <nav class="nav">
    <div class="nav-inner">
      <a class="brand" href="/" aria-label="Cloud Minds Partners — home">
        <img class="brand-wordmark" src="/logo/cmp-wordmark.png" alt="Cloud Minds Partners" />
        <span class="brand-tag">Data Center Advisory · LatAm</span>
      </a>
      <div class="nav-links">
        <a href="/advisory">Advisory</a>
        <a href="/development">Development</a>
        <a href="/intelligence">Intelligence</a>
        <a href="/platforms">Platforms</a>
        <a href="/team">Team</a>
      </div>
      <div class="nav-right">
        <div class="nav-lang">
          <a href="/" class="active">EN</a><span class="sep">·</span><a href="/pt/">PT</a><span class="sep">·</span><a href="/es/">ES</a>
        </div>
        <a href="mailto:info@cloudmindspartners.com" class="nav-cta">
          Talk to us
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 7h12M7 1l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <header class="home-hero">
    <div class="home-hero-slides" aria-hidden="true">
      <div class="home-hero-slide"></div>
      <div class="home-hero-slide"></div>
      <div class="home-hero-slide"></div>
    </div>
    <div class="home-hero-overlay" aria-hidden="true"></div>
    <div class="home-hero-grid" aria-hidden="true"></div>

    <div class="wrap">
      <div class="home-hero-content">
        <h1>Data center intelligence for <span class="blue">Latin&nbsp;America.</span></h1>
        <p>Advisory, development, and data center intelligence — applied across Brazil, Chile, and Mexico.</p>
        <div class="home-actions">
          <a class="btn-primary" href="mailto:info@cloudmindspartners.com">
            Engage advisory
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 7h12M7 1l6 6-6 6"/></svg>
          </a>
          <a class="btn-outline" href="/platforms">Open the platforms →</a>
        </div>
      </div>
    </div>

    <div class="home-hero-progress" aria-hidden="true">
      <div class="home-hero-progress-track"><div class="home-hero-progress-fill"></div></div>
      <div class="home-hero-progress-track"><div class="home-hero-progress-fill"></div></div>
      <div class="home-hero-progress-track"><div class="home-hero-progress-fill"></div></div>
    </div>
  </header>

  <section class="stats" aria-label="Coverage statistics">
    <div class="stats-inner">
      <div class="stat reveal">
        <div class="stat-num"><span class="stat-value">76</span><span class="unit">cities</span></div>
        <div class="stat-label">Working portfolio</div>
      </div>
      <div class="stat reveal reveal-delay-1">
        <div class="stat-num"><span class="stat-value">251</span><span class="unit">sites</span></div>
        <div class="stat-label">Greenfield pipeline</div>
      </div>
      <div class="stat reveal reveal-delay-2">
        <div class="stat-num"><span class="stat-value">508</span><span class="unit">studies</span></div>
        <div class="stat-label">Grid intelligence</div>
      </div>
      <div class="stat reveal reveal-delay-3">
        <div class="stat-num"><span class="stat-value">+18</span><span class="unit">GW</span></div>
        <div class="stat-label">Headroom 2028</div>
      </div>
    </div>
  </section>

  <section class="capabilities on-cream" id="platforms">
    <div class="wrap">
      <div class="reveal" style="text-align:center; margin-bottom: 24px;">
        <div class="section-eyebrow" style="justify-content:center;">Platforms</div>
