---
import V4Layout from "../components/v4/V4Layout.astro";
import LatAmGlobe from "../components/v4/LatAmGlobe.astro";
import TierRadar from "../components/v4/TierRadar.astro";
import TierIsometric from "../components/v4/TierIsometric.astro";
import TierNetwork from "../components/v4/TierNetwork.astro";
import { platforms as allPlatforms } from "../data/platforms";

const platforms = allPlatforms.slice(0, 6);

const tiers = [
  {
    n: "01",
    label: "Advisory",
    title: "Site selection and feasibility, calibrated to LatAm reality.",
    body: "We work the parts of a data center project that don't fit into a spreadsheet — regulatory path, grid context, environmental licensing, water and zoning. Brazil, Chile, Mexico, and the wider region.",
    href: "/advisory",
    cta: "Read advisory",
    stats: [
      { value: "76", label: "cities scored" },
      { value: "3", label: "countries primary" },
      { value: "30+", label: "test-fit presets" },
    ],
    visual: "radar" as const,
  },
  {
    n: "02",
    label: "Development",
    title: "Project execution from term sheet to first power.",
    body: "Owner-side support for sites under contract: permit strategy, land assembly, utility coordination, and construction governance — paced to a realistic timeline against a real grid.",
    href: "/development",
    cta: "Read development",
    stats: [
      { value: "8+", label: "active projects" },
      { value: "120MW", label: "in pipeline" },
      { value: "3", label: "countries deployed" },
    ],
    visual: "iso" as const,
  },
  {
    n: "03",
    label: "Intelligence",
    title: "Research products and weekly market signal.",
    body: "Technical memos, regulatory monitoring, and the DC Weekly Pulse — built on primary sources, audited before publication. Never US-centric. Always source-linked.",
    href: "/intelligence",
    cta: "Read intelligence",
    stats: [
      { value: "Weekly", label: "Pulse cadence" },
      { value: "Monthly", label: "regulatory watch" },
      { value: "5pp", label: "memo cap, 3+ sources" },
    ],
    visual: "network" as const,
  },
];
---

<V4Layout title="Cloud Minds Partners — Data Center Advisory for Latin America" active="home">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero has-visual">
    <div class="v4-page-hero-inner">
      <div>
        <span class="v4-eyebrow">Cloud Minds Partners · Established 2024</span>
        <h1 class="v4-display-xl">
          Data center projects in Latin America,<br/>
          <em class="v4-italic-rust">built on research.</em>
        </h1>
        <p class="v4-lede">
          Advisory, development, and intelligence for hyperscalers,
          colocators, developers, and funds — focused on Brazil, Chile,
          and Mexico. We work the parts of a project that don't fit into
          a spreadsheet.
        </p>
        <div class="v4-btn-row">
          <a href="/advisory" class="v4-btn v4-btn-primary">Engage advisory →</a>
          <a href="/platforms" class="v4-btn v4-btn-secondary">See platforms</a>
        </div>
      </div>
      <div>
        <LatAmGlobe />
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <section class="v4-trust">
    <div class="v4-trust-inner">
      <span class="v4-trust-label">Working contexts</span>
      <div class="v4-trust-marquee">
        <span>Hyperscaler site portfolio</span><span>·</span>
        <span>Colocator development</span><span>·</span>
        <span>Investment fund DD</span><span>·</span>
        <span>Greenfield permitting</span><span>·</span>
        <span>Brownfield reuse</span><span>·</span>
        <span>ZPE / REDATA structuring</span><span>·</span>
        <span>HV interconnection</span><span>·</span>
        <span>Water-rights sourcing</span><span>·</span>
        <span>Hyperscaler site portfolio</span><span>·</span>
        <span>Colocator development</span><span>·</span>
        <span>Investment fund DD</span><span>·</span>
        <span>Greenfield permitting</span>
      </div>
    </div>
  </section>

  <!-- ═══ TIERS ═══ -->
  {tiers.map((t, idx) => {
    const isDark = idx % 2 === 0;
    const sectionClass = isDark ? "v4-section v4-section-dark" : "v4-section v4-section-light";
    const textRight = !isDark; // light tier has text on right
    return (
      <section class={sectionClass}>
        <div class="v4-section-inner">
          <div class="v4-tier-grid">
            <div class={textRight ? "v4-tier-text-right" : ""}>
              <div class="v4-tier-num">{t.n} / {t.label}</div>
              <h2 class="v4-display-lg">{t.title}</h2>
              <p class={isDark ? "v4-lede" : "v4-lede v4-lede-light"}>{t.body}</p>
              <div class="v4-stats">
                {t.stats.map((s) => (
                  <div>
                    <div class="v4-stat-value">{s.value}</div>
                    <div class="v4-stat-label">{s.label}</div>
                  </div>
                ))}
              </div>
              <a href={t.href} class={isDark ? "v4-btn v4-btn-primary" : "v4-btn v4-btn-primary-dark"}>
                {t.cta} →
              </a>
            </div>
            <div class="v4-tier-visual">
              {t.visual === "radar" && <TierRadar />}
              {t.visual === "iso" && <TierIsometric />}
              {t.visual === "network" && <TierNetwork />}
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- ═══ PLATFORMS ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <span class="v4-eyebrow v4-eyebrow-light">Platforms</span>
      <h2 class="v4-display-lg" style="margin-bottom:16px;">Six tools we ship and maintain.</h2>
      <p class="v4-lede v4-lede-light" style="margin-bottom:56px;">
        Built for the work we do. Available to clients on engagement.
      </p>
      <div class="v4-card-grid">
        {platforms.map((p, i) => (
          <a href={p.url || "/platforms"} class="v4-card">
            <div class="v4-card-num">{String(i + 1).padStart(2, "0")} / {p.tag.toUpperCase()}</div>
            <h3 class="v4-card-name">{p.name}</h3>
            <p class="v4-card-desc">{p.summary}</p>
            <span class="v4-card-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BIG CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Have a site, deal, or thesis<br/>
        <em class="v4-italic-rust">that needs unpacking?</em>
      </h2>
      <p class="v4-big-cta-body">
        We engage on retainer, project, or success-fee depending on scope.
        First conversation is on us.
      </p>
      <a href="/contact" class="v4-btn v4-btn-primary v4-btn-large">Start a conversation →</a>
    </div>
  </section>
</V4Layout>
