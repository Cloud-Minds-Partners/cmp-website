---
import V4Layout from "../../components/v4/V4Layout.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import CarouselEmbed from "../../components/CarouselEmbed.astro";
import { platforms } from "../../data/platforms";

export async function getStaticPaths() {
  return platforms.map((p) => ({ params: { slug: p.slug }, props: { platform: p } }));
}

const { platform } = Astro.props;

const statusLabel: Record<string, string> = {
  "live": "Live",
  "beta": "Beta",
  "in-development": "In development",
};

const clientsLabel: Record<string, string> = {
  "open": "Public access",
  "engagement": "Available under engagement",
  "client-private": "Deployed per client — private",
};
---

<V4Layout title={`${platform.name} — Cloud Minds Partners`} description={platform.summary} active="platforms">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero">
    <div class="v4-page-hero-inner">
      <nav style="margin-bottom:20px;">
        <a href="/platforms" class="v4-back-link">← All platforms</a>
      </nav>
      <span class="v4-eyebrow">{platform.tag.toUpperCase()} · {statusLabel[platform.status]}</span>
      <h1 class="v4-display-xl" style="max-width:900px;">{platform.name}</h1>
      <p class="v4-lede">{platform.tagline}</p>
      <div class="v4-platform-meta">
        {platform.url && platform.showHost && (
          <a href={platform.url} target="_blank" rel="noopener" class="v4-platform-url">
            Open {new URL(platform.url).host} →
          </a>
        )}
        {platform.clients && (
          <span class="v4-platform-access">{clientsLabel[platform.clients]}</span>
        )}
      </div>
    </div>
  </section>

  <!-- ═══ OVERVIEW + MEDIA ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <div class="v4-platform-grid">
        <div class="v4-platform-left">
          <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:16px;">Overview</span>
          <p class="v4-platform-summary">{platform.summary}</p>

          <div style="margin-top:40px;">
            <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:16px;">Highlights</span>
            <ul class="v4-platform-highlights">
              {platform.highlights.map((h) => (
                <li>
                  <span class="v4-highlight-bullet">◆</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="v4-platform-right">
          <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:16px;">Demo video</span>
          <VideoEmbed url={platform.videoUrl ?? null} aspect="16/9"
            comingSoonLabel={`${platform.name} — video walkthrough in production`} />

          <div style="margin-top:40px;">
            <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:16px;">Walkthrough carousel</span>
            <CarouselEmbed slides={[]} aspect="portrait"
              comingSoonLabel={`${platform.name} — feature carousel in production`} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BODY SECTIONS ═══ -->
  {platform.body.length > 0 && (
    <section class="v4-section v4-section-light" style="padding-top:0;">
      <div class="v4-section-inner">
        <div class="v4-platform-body">
          {platform.body.map((b) => (
            <div class="v4-platform-body-section">
              <h2 class="v4-display-md">{b.heading}</h2>
              <p class="v4-platform-body-text">{b.content}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ ENGAGEMENT CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Interested in {platform.name}<br/>
        for a <em class="v4-italic-rust">specific project</em>?
      </h2>
      <p class="v4-big-cta-body">
        Platform access is part of every CMP engagement. Reach out to discuss scope and timing.
      </p>
      <a href="/contact" class="v4-btn v4-btn-primary v4-btn-large">Talk to us →</a>
    </div>
  </section>
</V4Layout>

<style>
  .v4-back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-ink-quiet);
    text-decoration: none;
  }
  .v4-back-link:hover { color: var(--color-rust); }

  .v4-platform-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    margin-top: 24px;
  }
  .v4-platform-url {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 600;
  }
  .v4-platform-url:hover { text-decoration: underline; }
  .v4-platform-access {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-ink-quiet);
  }

  .v4-platform-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .v4-platform-summary {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-ink);
    margin: 0;
  }

  .v4-platform-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .v4-platform-highlights li {
    display: flex;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink);
    margin-bottom: 16px;
  }
  .v4-highlight-bullet {
    color: var(--color-navy);
    flex-shrink: 0;
    margin-top: 2px;
    font-size: 10px;
  }

  .v4-platform-body {
    max-width: 760px;
    border-top: 1px solid var(--color-rule);
    padding-top: 56px;
  }
  .v4-platform-body-section {
    margin-bottom: 48px;
  }
  .v4-platform-body-text {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-ink);
    margin: 16px 0 0;
  }

  @media (max-width: 860px) {
    .v4-platform-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
