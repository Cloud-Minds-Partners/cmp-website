---
import Base from "../../layouts/Base.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Section from "../../components/Section.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import CarouselEmbed from "../../components/CarouselEmbed.astro";
import { platforms } from "../../data/platforms";

export async function getStaticPaths() {
  return platforms.map((p) => ({ params: { slug: p.slug }, props: { platform: p } }));
}

const { platform } = Astro.props;

const statusLabel: Record<string, string> = {
  "live": "Live",
  "beta": "Beta",
  "in-development": "In development",
};

const clientsLabel: Record<string, string> = {
  "open": "Public access",
  "engagement": "Available under engagement",
  "client-private": "Deployed per client — private",
};
---

<Base title={`${platform.name} — Cloud Minds Partners`} description={platform.summary}>
  <SiteHeader active="platforms" />

  <main>
    <section class="pt-20 pb-12 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <nav class="caption mb-6">
          <a href="/platforms" class="no-underline">← All platforms</a>
        </nav>
        <div class="eyebrow mb-3">{platform.tag} · {statusLabel[platform.status]}</div>
        <h1 class="display-lg max-w-3xl">{platform.name}</h1>
        <p class="lede mt-6 max-w-2xl">{platform.tagline}</p>
        <div class="mt-8 flex flex-wrap gap-x-8 gap-y-2 text-sm text-[var(--color-ink-muted)]">
          {platform.url && platform.showHost && (
            <a href={platform.url} target="_blank" rel="noopener" class="text-[var(--color-navy)] font-semibold no-underline">
              Open {new URL(platform.url).host} →
            </a>
          )}
          {platform.clients && (
            <span>{clientsLabel[platform.clients]}</span>
          )}
        </div>
      </div>
    </section>

    <Section compact>
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <div class="eyebrow mb-3">Overview</div>
          <p class="text-[var(--color-ink)] text-lg leading-relaxed mb-8">{platform.summary}</p>

          <div class="eyebrow mb-3">Highlights</div>
          <ul class="space-y-3 text-[var(--color-ink)]">
            {platform.highlights.map((h) => (
              <li class="flex gap-3 text-[15px] leading-relaxed">
                <span class="text-[var(--color-navy)] mt-1.5 shrink-0">◆</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="md:col-span-7">
          <div class="eyebrow mb-3">Demo video</div>
          <VideoEmbed url={platform.videoUrl ?? null} aspect="16/9" comingSoonLabel={`${platform.name} — video walkthrough in production`} />

          <div class="mt-10 eyebrow mb-3">Walkthrough carousel</div>
          <CarouselEmbed slides={[]} aspect="portrait" comingSoonLabel={`${platform.name} — feature carousel in production`} />
        </div>
      </div>
    </Section>

    {platform.body.length > 0 && (
      <Section tone="alt" compact>
        <div class="max-w-3xl space-y-10">
          {platform.body.map((b) => (
            <div>
              <h2 class="display text-2xl mb-4">{b.heading}</h2>
              <p class="text-[var(--color-ink)] leading-relaxed text-[17px]">{b.content}</p>
            </div>
          ))}
        </div>
      </Section>
    )}

    <Section tone="ink" compact>
      <div class="grid md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8">
          <div class="eyebrow text-[color:color-mix(in_srgb,var(--color-canvas)_60%,transparent)] mb-3">Engagement</div>
          <h2 class="display text-2xl md:text-3xl text-[var(--color-canvas)] max-w-2xl">
            Interested in {platform.name} for a specific project?
          </h2>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a
            href="mailto:info@cloudmindspartners.com"
            class="inline-block no-underline text-[var(--color-canvas)] border border-[var(--color-canvas)] px-5 py-2.5 hover:bg-[var(--color-canvas)] hover:text-[var(--color-ink)] transition-colors"
          >
            info@cloudmindspartners.com
          </a>
        </div>
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
