---
import V4Layout from "../components/v4/V4Layout.astro";
import NewsletterSubscribe from "../components/NewsletterSubscribe.astro";
import NewsletterArchive from "../components/NewsletterArchive.astro";
---

<V4Layout title="DC Insights Newsletter — Cloud Minds Partners" description="DC Insights — weekly digest of data center developments across Latin America." active="intelligence">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero">
    <div class="v4-page-hero-inner">
      <span class="v4-eyebrow">Newsletter</span>
      <h1 class="v4-display-xl" style="max-width:900px;">
        DC Insights — <em class="v4-italic-rust">Weekly Pulse</em>.
      </h1>
      <p class="v4-lede">
        Three to four LatAm-relevant data center stories every week. Deals,
        regulation, deployments, and infrastructure signals that rarely make the
        English-language trade press. Primary sources, audited before send.
      </p>
    </div>
  </section>

  <!-- ═══ SUBSCRIBE + ARCHIVE ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <div class="v4-nl-grid">
        <div class="v4-nl-subscribe">
          <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:24px;">Subscribe</span>
          <NewsletterSubscribe showHeadline={false} />

          <div class="v4-nl-meta">
            <div>
              <div class="v4-nl-meta-label">What you get</div>
              <ul class="v4-nl-list">
                <li>Weekly digest, curated from primary sources</li>
                <li>Deals, capacity announcements, policy moves</li>
                <li>LatAm-first editorial — BR, MX, CL, and the wider region</li>
                <li>No tracking beyond delivery confirmation</li>
              </ul>
            </div>
            <div style="margin-top:24px;">
              <div class="v4-nl-meta-label">Publishing</div>
              <p class="v4-nl-meta-body">Daily weekday dispatches plus a weekly Sunday roll-up.</p>
            </div>
          </div>
        </div>

        <div class="v4-nl-archive">
          <span class="v4-eyebrow v4-eyebrow-light" style="margin-bottom:24px;">Archive</span>
          <NewsletterArchive />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DARK STRIP ═══ -->
  <section class="v4-section v4-section-dark" style="padding-top:80px; padding-bottom:80px;">
    <div class="v4-section-narrow" style="text-align:center;">
      <h2 class="v4-display-lg">
        No filler. No hot takes.<br/>
        <em class="v4-italic-rust">Only what moves the market.</em>
      </h2>
      <div style="margin-top:32px;">
        <a href="mailto:info@cloudmindspartners.com?subject=Newsletter inquiry" class="v4-btn v4-btn-primary v4-btn-large">Get in touch →</a>
      </div>
    </div>
  </section>
</V4Layout>

<style>
  .v4-nl-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 80px;
    align-items: start;
  }

  .v4-nl-meta {
    margin-top: 32px;
  }
  .v4-nl-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-quiet);
    margin-bottom: 10px;
  }
  .v4-nl-list {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink-muted);
    padding-left: 18px;
    margin: 0;
  }
  .v4-nl-list li { margin: 6px 0; }
  .v4-nl-meta-body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink-muted);
    margin: 0;
  }

  @media (max-width: 860px) {
    .v4-nl-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
