---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Section from "../components/Section.astro";
import NewsletterSubscribe from "../components/NewsletterSubscribe.astro";
import NewsletterArchive from "../components/NewsletterArchive.astro";
---

<Base title="Newsletter — DC Insights" description="DC Insights — weekly digest of data center developments across Latin America.">
  <SiteHeader active="intelligence" />

  <main>
    <section class="pt-20 pb-16 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-4">Newsletter</div>
        <h1 class="display-lg max-w-3xl">DC Insights.</h1>
        <p class="lede mt-6 max-w-2xl">
          A weekly dispatch on data center developments across Latin America —
          deals, regulation, deployments, and the infrastructure signals that
          rarely make the English-language trade press.
        </p>
      </div>
    </section>

    <Section compact>
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <NewsletterSubscribe showHeadline={false} />
          <div class="mt-10 space-y-5 text-sm text-[var(--color-ink-muted)] leading-relaxed max-w-md">
            <div>
              <div class="eyebrow text-[11px] mb-2">What you get</div>
              <ul class="list-disc pl-5 space-y-1.5">
                <li>Weekly digest, curated from primary sources</li>
                <li>Deals, capacity announcements, policy moves</li>
                <li>LatAm-first editorial — BR, MX, CL, and the wider region</li>
                <li>No tracking beyond what Brevo does for delivery</li>
              </ul>
            </div>
            <div>
              <div class="eyebrow text-[11px] mb-2">Publishing</div>
              <p>Daily weekday dispatches plus a weekly Sunday roll-up.</p>
            </div>
          </div>
        </div>
        <div class="md:col-span-7">
          <NewsletterArchive />
        </div>
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
