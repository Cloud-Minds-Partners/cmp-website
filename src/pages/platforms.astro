---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Section from "../components/Section.astro";
import { platforms } from "../data/platforms";

const statusLabel: Record<string, string> = {
  "live": "Live",
  "beta": "Beta",
  "in-development": "In development",
};
---

<Base title="Platforms — Cloud Minds Partners" description="CMP proprietary platforms for data center site selection, market pricing, capacity modelling, and project tracking.">
  <SiteHeader active="platforms" />

  <main>
    <section class="pt-20 pb-16 border-b border-[var(--color-rule)]">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="eyebrow mb-4">Platforms</div>
        <h1 class="display-lg max-w-3xl">We productize what survives across engagements.</h1>
        <p class="lede mt-6 max-w-2xl">
          Our platforms are the tools we use on every project — not a
          separate business line. They are available to clients under
          engagement and become deliverables in their own right.
        </p>
      </div>
    </section>

    <Section compact>
      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {platforms.map((p) => (
          <a href={`/platforms/${p.slug}`} class="block py-10 no-underline hover:bg-[var(--color-surface)] -mx-6 px-6 transition-colors">
            <div class="grid md:grid-cols-12 gap-6">
              <div class="md:col-span-3">
                <div class="caption mb-2">{p.tag}</div>
                {p.url && p.showHost && <div class="caption text-[var(--color-navy)]">{new URL(p.url).host}</div>}
                <div class="caption mt-1 text-[var(--color-ink-quiet)]">{statusLabel[p.status]}</div>
              </div>
              <div class="md:col-span-9">
                <h2 class="display text-2xl mb-3">{p.name}</h2>
                <p class="text-[var(--color-ink)] leading-relaxed">{p.summary}</p>
                <span class="inline-block mt-5 text-sm font-semibold text-[var(--color-navy)]">Learn more →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>
