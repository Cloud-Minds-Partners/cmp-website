---
import V4Layout from "../components/v4/V4Layout.astro";
import { platforms } from "../data/platforms";

const statusLabel: Record<string, string> = {
  "live": "Live",
  "beta": "Beta",
  "in-development": "In development",
};
---

<V4Layout title="Platforms — Cloud Minds Partners" description="CMP proprietary platforms for data center site selection, market pricing, capacity modelling, and project tracking." active="platforms">
  <!-- ═══ HERO ═══ -->
  <section class="v4-page-hero">
    <div class="v4-page-hero-inner">
      <span class="v4-eyebrow">Platforms</span>
      <h1 class="v4-display-xl" style="max-width:1000px;">
        We productize <em class="v4-italic-rust">what survives</em><br/>across engagements.
      </h1>
      <p class="v4-lede">
        Our platforms are the tools we use on every project — not a separate business line.
        They are available to clients under engagement and become deliverables in their own right.
      </p>
    </div>
  </section>

  <!-- ═══ PLATFORM GRID ═══ -->
  <section class="v4-section v4-section-light">
    <div class="v4-section-inner">
      <div class="v4-card-grid">
        {platforms.map((p, i) => (
          <a href={`/platforms/${p.slug}`} class="v4-card">
            <div class="v4-card-num">
              {String(i+1).padStart(2,"0")} · {p.tag.toUpperCase()} · {statusLabel[p.status]}
            </div>
            <h3 class="v4-card-name">{p.name}</h3>
            <p class="v4-card-desc">{p.summary}</p>
            {p.url && p.showHost && (
              <span style="font-family:var(--font-mono); font-size:12px; color:var(--color-navy); margin-top:14px;">{new URL(p.url).host}</span>
            )}
            <span class="v4-card-arrow">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BIG CTA ═══ -->
  <section class="v4-big-cta">
    <div class="v4-big-cta-inner">
      <h2 class="v4-display-xl">
        Need access for a <em class="v4-italic-rust">specific deal</em>?
      </h2>
      <p class="v4-big-cta-body">
        Platform access is part of every CMP engagement. Reach out to discuss scope and timing.
      </p>
      <a href="/contact" class="v4-btn v4-btn-primary v4-btn-large">Talk to us →</a>
    </div>
  </section>
</V4Layout>
