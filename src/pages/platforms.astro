---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
---

<Base lang="en">
  <SEO
    slot="head"
    title="Platforms — Cloud Minds Partners"
    description="Tools we built. Now in production. Four platforms applied to live engagements across LatAm."
    image="/og/platforms.png"
  />

  <style slot="head" is:global>
    .page-hero-bg { background-image: url("/photos/hero-platforms.jpg"); }

    .products { padding: 0; }
    .product {
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: stretch;
      width: 100%;
    }
    .product-info {
      padding: clamp(56px, 8vh, 96px) clamp(48px, 6vw, 96px);
      display: flex; flex-direction: column; gap: 18px;
      align-items: center; justify-content: center;
      text-align: center;
    }
    .product-info-num {
      font-family: var(--font-body); font-size: 12.5px;
      font-weight: 600; letter-spacing: 0;
      color: var(--blue-bright);
    }
    .product-info h3 {
      font-family: var(--font-display); font-size: clamp(28px, 3.2vw, 40px);
      line-height: 1.1; letter-spacing: var(--track-display);
      font-weight: 600; margin: 0;
      color: var(--cream-0);
      max-width: 16ch;
    }
    .product-info > p {
      font-size: 15.5px; line-height: 1.55;
      color: var(--cream-1); margin: 0;
      max-width: 38ch;
    }
    .product-cta {
      margin-top: 8px;
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 14px; font-weight: 600;
      color: var(--blue-bright);
      padding-bottom: 4px;
      border-bottom: 1px solid var(--blue-bright);
      transition: gap var(--t-fast);
    }
    .product-cta:hover { gap: 16px; color: var(--cream-0); }

    .product:nth-child(1) .product-info { background: var(--navy-0); }
    .product:nth-child(2) .product-info { background: var(--cream-bg); }
    .product:nth-child(3) .product-info { background: var(--navy-0); }
    .product:nth-child(4) .product-info { background: var(--cream-bg); }

    .product:nth-child(2) .product-info,
    .product:nth-child(4) .product-info { color: var(--navy-0); }
    .product:nth-child(2) .product-info h3,
    .product:nth-child(4) .product-info h3 { color: var(--navy-0); }
    .product:nth-child(2) .product-info > p,
    .product:nth-child(4) .product-info > p { color: #4D5F7A; }
    .product:nth-child(2) .product-info-num,
    .product:nth-child(4) .product-info-num { color: var(--blue-deep); }
    .product:nth-child(2) .product-cta,
    .product:nth-child(4) .product-cta { color: var(--blue); border-color: var(--blue); }
    .product:nth-child(2) .product-cta:hover,
    .product:nth-child(4) .product-cta:hover { color: var(--navy-0); }

    .product:nth-child(even) .product-info { order: 2; }
    .product:nth-child(even) .product-visual { order: 1; }

    .product-visual { position: relative; min-height: 480px; overflow: hidden; }
    .product-visual-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
      animation: prodKen 22s ease-in-out infinite alternate;
      filter: saturate(1.15) contrast(1.05);
    }
    @keyframes prodKen { 0% { transform: scale(1); } 100% { transform: scale(1.07); } }

    @media (max-width: 880px) {
      .product { grid-template-columns: 1fr; }
      .product-visual { min-height: 280px; }
      .product:nth-child(even) .product-info { order: 1; }
      .product:nth-child(even) .product-visual { order: 2; }
    }
  </style>

  <nav class="nav">
    <div class="nav-inner">
      <a class="brand" href="/"><img class="brand-wordmark" src="/logo/cmp-wordmark.png" alt="Cloud Minds Partners" /><span class="brand-tag">Data Center Advisory · LatAm</span></a>
      <div class="nav-links"><a href="/advisory">Advisory</a><a href="/development">Development</a><a href="/intelligence">Intelligence</a><a href="/platforms" class="active">Platforms</a><a href="/team">Team</a></div>
      <div class="nav-right"><div class="nav-lang">
        <a href="/platforms" class="active">EN</a><span class="sep">·</span><a href="/pt/">PT</a><span class="sep">·</span><a href="/es/">ES</a>
      </div>
      <a href="mailto:info@cloudmindspartners.com" class="nav-cta">Talk to us <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7h12M7 1l6 6-6 6"/></svg></a></div>
    </div>
  </nav>

  <header class="page-hero">
    <div class="page-hero-bg" aria-hidden="true"></div>
    <div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="wrap">
      <div class="page-hero-content">
        <div class="page-eyebrow live">Platforms</div>
        <h1>Tools we built. <em>Now in production.</em></h1>
        <p>Four platforms applied to live engagements across LatAm.</p>
      </div>
    </div>
  </header>

  <section class="products">

    <article class="product reveal">
      <div class="product-info">
        <div class="product-info-num">01 — Site Selection</div>
        <h3>Score 76 cities in minutes.</h3>
        <p>Land, grid, water, fiber, climate, fiscal — weighted to the thesis.</p>
        <a class="product-cta" href="#">Open platform →</a>
      </div>
      <div class="product-visual"><div class="product-visual-bg" style="background-image: url('/photos/card-platform-site-selection.jpg');"></div></div>
    </article>

    <article class="product reveal">
      <div class="product-info">
        <div class="product-info-num">02 — Grid Intelligence</div>
        <h3>508 ONS studies. Indexed.</h3>
        <p>PARPEL 2027–2031 modeled by substation. N-1 contingency in 24h.</p>
        <a class="product-cta" href="#">Open platform →</a>
      </div>
      <div class="product-visual"><div class="product-visual-bg" style="background-image: url('/photos/card-platform-grid-intel.jpg');"></div></div>
    </article>

    <article class="product reveal">
      <div class="product-info">
        <div class="product-info-num">03 — DC Financial Model</div>
        <h3>Country-specific TCO.</h3>
        <p>BR · CL · MX tariffs, capex curves by tier, sensitivity by FX and DSCR.</p>
        <a class="product-cta" href="#">Open platform →</a>
      </div>
      <div class="product-visual"><div class="product-visual-bg" style="background-image: url('/photos/card-platform-dc-financial.jpg');"></div></div>
    </article>

    <article class="product reveal">
      <div class="product-info">
        <div class="product-info-num">04 — Test Fit Pro</div>
        <h3>Engineering-grade layouts.</h3>
        <p>Hyperscale and edge campuses. 30 vendor presets. EIAR-compliant.</p>
        <a class="product-cta" href="#">Open platform →</a>
      </div>
      <div class="product-visual"><div class="product-visual-bg" style="background-image: url('/photos/card-platform-testfit-pro.jpg');"></div></div>
    </article>

  </section>

  <footer>
    <div class="foot-links">
      <div class="foot-brand-cell">
        <a class="brand" href="/"><img class="brand-wordmark" src="/logo/cmp-wordmark.png" alt="Cloud Minds Partners" /></a>
        <p>Data center intelligence for Latin America.</p>
        <div class="foot-social" aria-label="Follow us">
          <a href="https://www.linkedin.com/company/cloud-minds-partners" aria-label="LinkedIn" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.97 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0z"/></svg></a>
          <a href="https://wa.me/5511999999999" aria-label="WhatsApp" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.5-.6.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.7.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 2-1.4.2-.7.2-1.3.2-1.4 0-.1-.3-.2-.5-.3zM12 22a10 10 0 0 1-5-1.3L2 22l1.3-5A10 10 0 1 1 12 22zm0-18.2A8.2 8.2 0 0 0 4.6 16l-.2.5-.8 3 3-.8.5.2c1.2.7 2.6 1.1 4 1.1 4.5 0 8.2-3.7 8.2-8.2S16.5 3.8 12 3.8z"/></svg></a>
        </div>
      </div>
      <div><h4>Platforms</h4><ul><li><a href="/platforms">Site Selection</a></li><li><a href="/platforms">Grid Intelligence</a></li><li><a href="/platforms">Financial Model</a></li><li><a href="/platforms">Test Fit Pro</a></li></ul></div>
      <div><h4>Intelligence</h4><ul><li><a href="/intelligence">Technical Memos</a></li><li><a href="/intelligence">Innovation Radar</a></li><li><a href="/intelligence">Regulatory Watch</a></li><li><a href="/intelligence">Weekly Pulse</a></li></ul></div>
      <div><h4>Company</h4><ul><li><a href="/advisory">Advisory</a></li><li><a href="/development">Development</a></li><li><a href="/team">Team</a></li></ul></div>
      <div><h4>Contact</h4><ul><li><a href="mailto:info@cloudmindspartners.com">info@cloudmindspartners.com</a></li><li>São Paulo · BR</li><li>Santiago · CL</li><li>Mexico City · MX</li></ul></div>
    </div>
    <div class="foot-bottom"><span>© 2026 Cloud Minds Partners</span><span>All rights reserved.</span></div>
  </footer>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</Base>
