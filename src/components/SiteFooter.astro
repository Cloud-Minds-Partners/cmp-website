---
import SocialLinks from "./SocialLinks.astro";
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="mt-32 bg-[var(--color-dark-bg)] text-[var(--color-dark-ink)] relative overflow-hidden">
  <div class="absolute inset-0 dot-grid-dark opacity-40" aria-hidden="true"></div>

  <div class="relative max-w-[1280px] mx-auto px-6 py-16 grid grid-cols-2 md:grid-cols-5 gap-10 text-sm">
    <div class="col-span-2 md:col-span-2">
      <Logo variant="white" height={28} />
      <p class="mt-5 text-[var(--color-dark-ink-muted)] max-w-xs leading-relaxed">
        Data center advisory, project development, and intelligence across Latin America.
      </p>
      <a href="mailto:info@cloudmindspartners.com" class="mt-4 inline-block caption text-[var(--color-accent-bright)]">
        info@cloudmindspartners.com
      </a>
      <div class="mt-6">
        <SocialLinks variant="dark" />
      </div>
    </div>

    <div>
      <div class="eyebrow-dark mb-4">Services</div>
      <ul class="space-y-2 text-[var(--color-dark-ink-muted)]">
        <li><a href="/advisory" class="hover:text-[var(--color-dark-ink)] transition-colors">Advisory</a></li>
        <li><a href="/development" class="hover:text-[var(--color-dark-ink)] transition-colors">Development</a></li>
        <li><a href="/intelligence" class="hover:text-[var(--color-dark-ink)] transition-colors">Intelligence</a></li>
      </ul>
    </div>

    <div>
      <div class="eyebrow-dark mb-4">Intelligence</div>
      <ul class="space-y-2 text-[var(--color-dark-ink-muted)]">
        <li><a href="/intelligence/memos" class="hover:text-[var(--color-dark-ink)] transition-colors">Technical Memos</a></li>
        <li><a href="/intelligence/radar" class="hover:text-[var(--color-dark-ink)] transition-colors">Innovation Radar</a></li>
        <li><a href="/intelligence/regwatch" class="hover:text-[var(--color-dark-ink)] transition-colors">Regulatory Watch</a></li>
        <li><a href="/newsletter" class="hover:text-[var(--color-dark-ink)] transition-colors">Newsletter</a></li>
      </ul>
    </div>

    <div>
      <div class="eyebrow-dark mb-4">About</div>
      <ul class="space-y-2 text-[var(--color-dark-ink-muted)]">
        <li><a href="/team" class="hover:text-[var(--color-dark-ink)] transition-colors">Team</a></li>
        <li><a href="/platforms" class="hover:text-[var(--color-dark-ink)] transition-colors">Platforms</a></li>
        <li><a href="/contact" class="hover:text-[var(--color-dark-ink)] transition-colors">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="relative border-t border-[var(--color-dark-border)]">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-2 text-xs text-[color:color-mix(in_srgb,var(--color-dark-ink-muted)_70%,transparent)]">
      <span>© {year} Cloud Minds Partners · All rights reserved</span>
      <span class="caption !text-[color:color-mix(in_srgb,var(--color-dark-ink-muted)_70%,transparent)]">São Paulo · Data Center Advisory for LatAm</span>
    </div>
  </div>
</footer>
