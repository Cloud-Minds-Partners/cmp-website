---
import Logo from './Logo.astro';
import SocialLinks from './SocialLinks.astro';
import { social } from '../config/social';

const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="foot-links">
    <!-- Brand cell -->
    <div class="foot-brand">
      <Logo variant="white" height={28} />
      <p class="foot-tagline">The LatAm DC intelligence firm.</p>
      <SocialLinks variant="footer" />
    </div>

    <!-- Platforms column -->
    <div class="foot-col">
      <p class="foot-heading">Platforms</p>
      <a href="/platforms/site-selection">Site Selection</a>
      <a href="/platforms/grid-intelligence">Grid Intelligence</a>
      <a href="/platforms/dc-financial">Financial Model</a>
      <a href="/platforms/test-fit-pro">Test Fit Pro</a>
    </div>

    <!-- Intelligence column -->
    <div class="foot-col">
      <p class="foot-heading">Intelligence</p>
      <a href="/intelligence/memos">Technical Memos</a>
      <a href="/intelligence/radar">Innovation Radar</a>
      <a href="/intelligence/regwatch">Regulatory Watch</a>
      <a href="/intelligence/pulse">Weekly Pulse</a>
    </div>

    <!-- Company column -->
    <div class="foot-col">
      <p class="foot-heading">Company</p>
      <a href="/advisory">Advisory</a>
      <a href="/development">Development</a>
      <a href="/team">Team</a>
    </div>

    <!-- Contact column -->
    <div class="foot-col">
      <p class="foot-heading">Contact</p>
      <a href={`mailto:${social.emailGeneral}`}>{social.emailGeneral}</a>
      <span>São Paulo · BR</span>
      <span>Santiago · CL</span>
      <span>Mexico City · MX</span>
    </div>
  </div>

  <!-- Copyright row -->
  <div class="foot-bottom">
    <span>© {currentYear} Cloud Minds Partners. All rights reserved.</span>
    <span>The LatAm DC intelligence firm.</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy-0);
    padding-top: 80px;
  }
  .foot-links {
    display: grid;
    grid-template-columns: minmax(280px, 1.4fr) 1fr 1fr 1fr 1fr;
    gap: clamp(40px, 4vw, 80px);
    padding: 0 clamp(32px, 5vw, 96px) 64px;
  }
  /* Brand cell */
  .foot-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .foot-tagline {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-cream-2);
    margin: 0;
    line-height: 1.5;
  }
  /* Link columns */
  .foot-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .foot-heading {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--color-cream-0);
    margin: 0 0 6px;
  }
  .foot-col a,
  .foot-col span {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-cream-1);
    text-decoration: none;
    transition: color 0.15s;
  }
  .foot-col a:hover {
    color: var(--color-blue-bright);
  }
  /* Copyright */
  .foot-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px clamp(32px, 5vw, 96px);
    border-top: 1px solid var(--color-line-0);
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-cream-2);
    flex-wrap: wrap;
    gap: 8px;
  }
  /* Responsive: stack footer columns on mobile */
  @media (max-width: 768px) {
    .foot-links {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .foot-links {
      grid-template-columns: 1fr;
    }
  }
</style>
