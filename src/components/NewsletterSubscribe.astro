---
import { social } from "../config/social";
interface Props {
  variant?: "default" | "inline" | "dark";
  showHeadline?: boolean;
}
const { variant = "default", showHeadline = true } = Astro.props;

const inputCls = variant === "dark"
  ? "bg-transparent border-[var(--color-canvas)]/40 text-[var(--color-canvas)] placeholder:text-[var(--color-canvas)]/50 focus:border-[var(--color-canvas)]"
  : "bg-[var(--color-surface)] border-[var(--color-rule)] text-[var(--color-ink)] placeholder:text-[var(--color-ink-quiet)] focus:border-[var(--color-navy)]";

const btnCls = variant === "dark"
  ? "bg-[var(--color-canvas)] text-[var(--color-ink)] hover:bg-[var(--color-canvas)]/90"
  : "bg-[var(--color-navy)] text-[var(--color-canvas)] hover:bg-[var(--color-navy-deep)]";

const uid = `nl-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="newsletter-subscribe" data-variant={variant}>
  {showHeadline && (
    <div class="mb-6">
      <div class={`eyebrow mb-2 ${variant === "dark" ? "text-[var(--color-canvas)]/60" : ""}`}>Newsletter</div>
      <h3 class={`display text-2xl md:text-3xl ${variant === "dark" ? "text-[var(--color-canvas)]" : "text-[var(--color-ink)]"}`}>
        DC Insights.
      </h3>
      <p class={`mt-3 text-sm leading-relaxed max-w-md ${variant === "dark" ? "text-[var(--color-canvas)]/75" : "text-[var(--color-ink-muted)]"}`}>
        A weekly digest of data center developments across Latin America —
        deals, regulation, infrastructure, and market signals. Free.
      </p>
    </div>
  )}

  <form id={uid} class="flex flex-col sm:flex-row gap-3 max-w-md" novalidate>
    <input
      type="email"
      name="email"
      required
      placeholder="you@company.com"
      autocomplete="email"
      class={`flex-1 border px-4 py-3 text-base outline-none focus:ring-0 transition-colors ${inputCls}`}
    />
    <button
      type="submit"
      class={`px-5 py-3 font-semibold text-sm tracking-wide transition-colors whitespace-nowrap ${btnCls}`}
    >
      Subscribe
    </button>
  </form>
  <p id={`${uid}-msg`} class={`mt-3 text-sm hidden ${variant === "dark" ? "text-[var(--color-canvas)]/80" : "text-[var(--color-ink-muted)]"}`}></p>
</div>

<script is:inline define:vars={{ uid, endpoint: social.subscribeEndpoint, landing: social.newsletterLanding }}>
  const form = document.getElementById(uid);
  const msg = document.getElementById(`${uid}-msg`);
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form).get("email");
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(email))) {
      show("Please enter a valid email.", "error");
      return;
    }
    const btn = form.querySelector("button");
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = "Sending…";
    try {
      const r = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: String(email).trim().toLowerCase() }),
      });
      const data = await r.json().catch(() => ({}));
      if (r.ok && (data.status === "subscribed" || data.status === "already_subscribed")) {
        show(data.status === "already_subscribed" ? "You're already on the list. See you Friday." : "Thanks — you're in. Check your inbox for confirmation.", "ok");
        form.reset();
      } else {
        show(data.error || "Something went wrong. Try again in a minute.", "error");
      }
    } catch {
      show("Couldn't reach the server. Try again in a minute.", "error");
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  });

  function show(text, kind) {
    if (!msg) return;
    msg.textContent = text;
    msg.classList.remove("hidden");
    msg.style.color = kind === "error" ? "#C1472A" : "";
  }
</script>
