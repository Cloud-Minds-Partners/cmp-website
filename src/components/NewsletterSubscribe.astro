---
import { social } from "../config/social";
interface Props {
  showHeadline?: boolean;
}
const { showHeadline = true } = Astro.props;
const uid = `nl-${Math.random().toString(36).slice(2, 8)}`;
---

<div>
  {showHeadline && (
    <div class="mb-7">
      <div class="eyebrow mb-3">Newsletter</div>
      <h3 style="font-family:var(--font-display);" class="text-[1.875rem] font-medium text-[var(--color-ink)]">DC Insights.</h3>
      <p class="mt-4 text-[15px] leading-relaxed text-[var(--color-ink-secondary)] max-w-md">
        A weekly digest of data center developments across Latin America —
        deals, regulation, infrastructure, and market signals. Free.
      </p>
    </div>
  )}

  <form id={uid} class="flex flex-col sm:flex-row gap-2 max-w-md" novalidate>
    <input
      type="email"
      name="email"
      required
      placeholder="you@company.com"
      autocomplete="email"
      class="flex-1 bg-[var(--color-bg-surface)] border border-[var(--color-border)] text-[var(--color-ink)] placeholder:text-[var(--color-ink-quiet)] px-4 py-3 text-[14px] outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[color:color-mix(in_srgb,var(--color-accent)_20%,transparent)] transition-all rounded-md"
    />
    <button type="submit" class="btn btn-primary whitespace-nowrap">
      Subscribe
    </button>
  </form>
  <p id={`${uid}-msg`} class="mt-3 text-sm hidden"></p>
</div>

<script is:inline define:vars={{ uid, endpoint: social.subscribeEndpoint }}>
  const form = document.getElementById(uid);
  const msg = document.getElementById(`${uid}-msg`);
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form).get("email");
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(email))) {
      show("Please enter a valid email.", "error");
      return;
    }
    const btn = form.querySelector("button");
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = "Sending…";
    try {
      const r = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: String(email).trim().toLowerCase() }),
      });
      const data = await r.json().catch(() => ({}));
      if (r.ok && (data.status === "subscribed" || data.status === "already_subscribed")) {
        show(data.status === "already_subscribed" ? "You're already on the list. See you Friday." : "Thanks — you're in. Check your inbox for confirmation.", "ok");
        form.reset();
      } else {
        show(data.error || "Something went wrong. Try again in a minute.", "error");
      }
    } catch {
      show("Couldn't reach the server. Try again in a minute.", "error");
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  });
  function show(text, kind) {
    if (!msg) return;
    msg.textContent = text;
    msg.classList.remove("hidden");
    msg.style.color = kind === "error" ? "#E05252" : "#00B8A9";
  }
</script>
