---
interface PulseEntry {
  date: string;
  label: string;
  videoUrl: string | null;
  poster: string | null;
}
const latest: PulseEntry | null = null;
---

<div class="grid md:grid-cols-12 gap-12 items-center">
  <div class="md:col-span-5">
    <div class="eyebrow mb-4">Weekly Pulse</div>
    <h2 style="font-family:var(--font-display);" class="text-[2rem] md:text-[2.5rem] font-medium leading-tight tracking-tight mb-6 text-[var(--color-ink)]">
      44 seconds on<br />the LatAm DC week.
    </h2>
    <p class="lede mb-8">
      A short weekly video brief on the signals that moved — deals, policy,
      deployments, outages — across Brazil, Chile, and Mexico.
    </p>
    <a href="/intelligence/radar" class="link-slide text-[14px] font-medium text-[var(--color-accent-bright)]">
      Browse all pulses →
    </a>
  </div>

  <div class="md:col-span-7">
    <div class="relative aspect-square bg-[var(--color-bg-sunken)] overflow-hidden border border-[var(--color-border)] rounded-sm">
      <div class="absolute inset-0 grid-bg opacity-30" aria-hidden="true"></div>
      <div class="absolute inset-0 hero-glow opacity-60" aria-hidden="true"></div>
      {latest?.videoUrl ? (
        <video class="absolute inset-0 w-full h-full object-cover" controls preload="metadata" poster={latest.poster ?? undefined}>
          <source src={latest.videoUrl} type="video/mp4" />
        </video>
      ) : (
        <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
          <button class="w-20 h-20 rounded-full border border-[var(--color-border-bright)] bg-[var(--color-bg-elevated)]/80 backdrop-blur-sm flex items-center justify-center mb-6 hover:border-[var(--color-accent)] hover:shadow-[var(--glow-blue)] transition-all group" aria-label="Play">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-accent-bright)] group-hover:text-[var(--color-ink)] ml-1 transition-colors" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
          <div class="caption mb-2">Coming soon</div>
          <div class="text-[14px] text-[var(--color-ink-muted)] max-w-xs leading-relaxed">
            Weekly Pulse episodes are being prepared for public release.
          </div>
        </div>
      )}
    </div>
    {latest && (
      <div class="mt-4 flex items-baseline justify-between text-sm">
        <span class="caption tabular-nums">{latest.date}</span>
        <span class="text-[var(--color-ink-muted)]">{latest.label}</span>
      </div>
    )}
  </div>
</div>
