---
// Weekly Pulse — 44-second weekly video brief.
// Today: videos exist locally in remotion-studio/out/weekly-pulse/YYYY-MM-DD/
// but aren't publicly hosted. This component renders an editorial shell until
// the video hosting is wired (Firebase Storage / YouTube embed / direct CDN).

import { social } from "../config/social";

interface PulseEntry {
  date: string;              // "2026-04-21"
  label: string;             // "Week 17"
  videoUrl: string | null;
  poster: string | null;
  summary?: string;
}

// TODO(pulse): wire to real data once Firebase Storage / YouTube uploads are set up.
const latest: PulseEntry | null = null;
---

<div class="grid md:grid-cols-12 gap-10 items-center">
  <div class="md:col-span-5">
    <div class="eyebrow mb-3">Weekly Pulse</div>
    <h2 class="display text-3xl md:text-[2.5rem] leading-tight tracking-tight mb-5">
      44 seconds on<br />the LatAm data center week.
    </h2>
    <p class="lede mb-6">
      A short weekly video brief on the signals that moved — deals, policy,
      deployments, outages — across Brazil, Chile, and Mexico.
    </p>
    <a href="/intelligence/radar" class="inline-block text-[var(--color-navy)] font-semibold text-sm no-underline">
      Browse all pulses →
    </a>
  </div>

  <div class="md:col-span-7">
    <div class="relative aspect-square md:aspect-square bg-[var(--color-ink)] overflow-hidden border border-[var(--color-rule)]">
      {latest?.videoUrl ? (
        <video
          class="absolute inset-0 w-full h-full object-cover"
          controls
          preload="metadata"
          poster={latest.poster ?? undefined}
        >
          <source src={latest.videoUrl} type="video/mp4" />
        </video>
      ) : (
        <div class="absolute inset-0 flex flex-col items-center justify-center text-[var(--color-canvas)] p-8 text-center">
          <div class="w-16 h-16 rounded-full border-2 border-[var(--color-canvas)]/60 flex items-center justify-center mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <div class="caption text-[var(--color-canvas)]/60 mb-2">Coming soon</div>
          <div class="text-sm text-[var(--color-canvas)]/80 max-w-xs leading-relaxed">
            Weekly Pulse episodes are being prepared for public release.
          </div>
        </div>
      )}
    </div>
    {latest && (
      <div class="mt-3 flex items-baseline justify-between text-sm">
        <span class="caption tabular-nums">{latest.date}</span>
        <span class="text-[var(--color-ink-muted)]">{latest.label}</span>
      </div>
    )}
  </div>
</div>
