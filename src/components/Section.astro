---
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  tone?: "default" | "elevated" | "bright";
  id?: string;
  compact?: boolean;
}
const { eyebrow, title, lede, tone = "default", id, compact = false } = Astro.props;

const bg = {
  default: "bg-[var(--color-bg-base)]",
  elevated: "bg-[var(--color-bg-elevated)]",
  bright: "bg-[var(--color-bg-overlay)]",
}[tone];

const py = compact ? "py-16" : "py-24 md:py-28";
---

<section id={id} class={`${bg} ${py} relative`}>
  <div class="max-w-[1280px] mx-auto px-6 relative">
    {(eyebrow || title || lede) && (
      <header class="mb-14 max-w-3xl">
        {eyebrow && <div class="eyebrow mb-4">{eyebrow}</div>}
        {title && <h2 class="display text-3xl md:text-[2.5rem] text-[var(--color-ink)]">{title}</h2>}
        {lede && <p class="lede mt-5">{lede}</p>}
      </header>
    )}
    <slot />
  </div>
</section>
