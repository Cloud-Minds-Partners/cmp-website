---
import SocialLinks from "./SocialLinks.astro";
import Logo from "./Logo.astro";

interface Props {
  active?: "home" | "advisory" | "development" | "intelligence" | "platforms" | "team" | "contact";
  subnav?: Array<{ href: string; label: string; active?: boolean }>;
}
const { active = "home", subnav } = Astro.props;

const primary = [
  { href: "/advisory", label: "Advisory", key: "advisory" as const },
  { href: "/development", label: "Development", key: "development" as const },
  { href: "/intelligence", label: "Intelligence", key: "intelligence" as const },
  { href: "/platforms", label: "Platforms", key: "platforms" as const },
  { href: "/team", label: "Team", key: "team" as const },
];

const linkCls = (k: string) =>
  active === k
    ? "text-[var(--color-ink)] font-medium"
    : "text-[var(--color-ink-muted)] hover:text-[var(--color-ink)]";
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-bg)_85%,transparent)] backdrop-blur-lg">
  <div class="max-w-[1280px] mx-auto px-6 flex items-center justify-between h-[68px]">
    <a href="/" class="flex items-center no-underline" aria-label="Cloud Minds Partners — Home">
      <Logo variant="navy" height={28} />
    </a>

    <nav class="hidden md:flex items-center gap-8 text-[14px]">
      {primary.map((item) => (
        <a href={item.href} class={`link-slide transition-colors ${linkCls(item.key)}`}>
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class={`btn btn-primary !py-2 !px-4 !text-[13px] ${active === "contact" ? "bg-[var(--color-accent)]" : ""}`}
      >
        Contact
      </a>
      <span class="w-px h-5 bg-[var(--color-border)]"></span>
      <SocialLinks />
    </nav>

    <button
      id="mobile-toggle"
      class="md:hidden text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] transition-colors"
      aria-label="Menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <line x1="4" y1="8" x2="20" y2="8"/>
        <line x1="4" y1="16" x2="20" y2="16"/>
      </svg>
    </button>
  </div>

  <nav id="mobile-nav" class="md:hidden hidden border-t border-[var(--color-border)] bg-[var(--color-bg-surface)]">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-col gap-4 text-[15px]">
      {primary.map((item) => (
        <a href={item.href} class={`no-underline ${linkCls(item.key)}`}>{item.label}</a>
      ))}
      <a href="/contact" class="no-underline text-[var(--color-accent)] font-medium">Contact</a>
      <div class="pt-3 border-t border-[var(--color-border)]">
        <SocialLinks />
      </div>
    </div>
  </nav>

  {subnav && subnav.length > 0 && (
    <div class="border-t border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
      <div class="max-w-[1280px] mx-auto px-6 h-10 flex items-center gap-6 text-xs overflow-x-auto">
        {subnav.map((s) => (
          <a
            href={s.href}
            class={`no-underline whitespace-nowrap link-slide ${s.active ? "text-[var(--color-accent)] font-medium" : "text-[var(--color-ink-muted)] hover:text-[var(--color-ink)]"}`}
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
  )}
</header>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const nav = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => nav?.classList.toggle("hidden"));
</script>
