---
// Multi-criteria radar — Advisory tier visual.
// Rich SVG with 7 evaluation axes (Land, Power, Water, Connectivity, Tax, Regulatory, Risk),
// scoring polygon, pulsing nodes, rotating sweep.
const axes = ["Land", "Power", "Water", "Connectivity", "Tax", "Regulatory", "Risk"];
const scores = [0.78, 0.92, 0.55, 0.85, 0.68, 0.72, 0.80]; // 0-1 normalized
const N = axes.length;
const rMax = 86;

function point(i: number, r: number) {
  const a = (Math.PI * 2 * i) / N - Math.PI / 2;
  return [Math.cos(a) * r, Math.sin(a) * r];
}

const polyPoints = scores.map((s, i) => point(i, s * rMax).join(",")).join(" ");
const labelPositions = axes.map((_, i) => point(i, rMax + 14));
const axisEndPoints = axes.map((_, i) => point(i, rMax));
---

<svg viewBox="-120 -120 240 240" class="tier-svg" aria-hidden="true">
  <defs>
    <radialGradient id="radar-glow" cx="50%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#C1472A" stop-opacity="0.18"/>
      <stop offset="60%" stop-color="#C1472A" stop-opacity="0.04"/>
      <stop offset="100%" stop-color="transparent" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="radar-fill" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#C1472A" stop-opacity="0.30"/>
      <stop offset="100%" stop-color="#1D4289" stop-opacity="0.30"/>
    </linearGradient>
  </defs>

  <!-- ambient glow -->
  <circle cx="0" cy="0" r="120" fill="url(#radar-glow)"/>

  <!-- concentric grid -->
  {[0.25, 0.5, 0.75, 1.0].map((f) => (
    <circle cx="0" cy="0" r={rMax * f} fill="none" stroke="rgba(245,241,232,0.10)" stroke-width="1" />
  ))}

  <!-- axis lines -->
  {axisEndPoints.map(([x, y]) => (
    <line x1="0" y1="0" x2={x} y2={y} stroke="rgba(245,241,232,0.15)" stroke-width="1" />
  ))}

  <!-- score polygon -->
  <polygon points={polyPoints} fill="url(#radar-fill)" stroke="#C1472A" stroke-width="1.5" stroke-linejoin="round">
    <animateTransform attributeName="transform" type="scale" values="0.92;1;0.92" dur="6s" repeatCount="indefinite" />
  </polygon>

  <!-- pulsing dots at score points -->
  {scores.map((s, i) => {
    const [x, y] = point(i, s * rMax);
    return (
      <g>
        <circle cx={x} cy={y} r="3.5" fill="#C1472A">
          <animate attributeName="r" values="3.5;5.5;3.5" dur={`${3 + (i % 3)}s`} repeatCount="indefinite" begin={`${i * 0.3}s`} />
        </circle>
        <circle cx={x} cy={y} r="3.5" fill="none" stroke="#C1472A" stroke-width="1" opacity="0.5">
          <animate attributeName="r" from="4" to="12" dur="2s" repeatCount="indefinite" begin={`${i * 0.4}s`} />
          <animate attributeName="opacity" from="0.6" to="0" dur="2s" repeatCount="indefinite" begin={`${i * 0.4}s`} />
        </circle>
      </g>
    );
  })}

  <!-- center hub -->
  <circle cx="0" cy="0" r="4" fill="#F5F1E8" />
  <circle cx="0" cy="0" r="6" fill="none" stroke="#F5F1E8" stroke-width="1" opacity="0.5" />

  <!-- rotating sweep -->
  <g>
    <line x1="0" y1="0" x2="0" y2="-86" stroke="rgba(193,71,42,0.6)" stroke-width="1.5"/>
    <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="14s" repeatCount="indefinite"/>
  </g>

  <!-- axis labels -->
  {axes.map((label, i) => {
    const [x, y] = labelPositions[i];
    return (
      <text x={x} y={y} fill="rgba(245,241,232,0.7)" font-size="9" font-family="Inter, sans-serif" text-anchor="middle" dominant-baseline="middle" letter-spacing="0.05em">
        {label.toUpperCase()}
      </text>
    );
  })}
</svg>

<style>
  .tier-svg {
    width: 100%;
    height: 100%;
    max-width: 520px;
    max-height: 520px;
    display: block;
    margin: 0 auto;
  }
</style>
