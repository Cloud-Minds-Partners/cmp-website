---
// Latest N DC Insights editions. Shell for when archive exists.
// Today: no public per-edition archive (dcinsights serves only landing/subscribe).
// Plan: (a) Brevo Campaigns API at build time OR (b) content-pipeline publishes
// each digest to `dcinsights.web.app/daily/YYYY-MM-DD.html` with 30d retention.
// Both produce the same rendering shape below.

import { social } from "../config/social";

interface Edition {
  date: string;         // "YYYY-MM-DD"
  title: string;        // short editorial headline
  url: string | null;   // null = coming soon
}

// TODO(editions): wire to real data source once archive path is live.
const editions: Edition[] = [];
const hasData = editions.length > 0;
---

<div>
  <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
    <div>
      <div class="eyebrow mb-1">Recent editions</div>
      <h3 class="display text-2xl md:text-3xl">Last seven dispatches.</h3>
    </div>
    <a href={social.newsletterLanding} target="_blank" rel="noopener" class="no-underline caption text-[var(--color-navy)]">
      View on dcinsights.web.app →
    </a>
  </div>

  {hasData ? (
    <ul class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
      {editions.slice(0, 7).map((ed) => (
        <li>
          <a
            href={ed.url ?? social.newsletterLanding}
            target="_blank"
            rel="noopener"
            class="block py-4 no-underline hover:bg-[var(--color-surface)] -mx-6 px-6 transition-colors"
          >
            <div class="grid grid-cols-12 gap-4 items-baseline">
              <div class="col-span-3 caption tabular-nums">{ed.date}</div>
              <div class="col-span-8 text-[var(--color-ink)] leading-snug">{ed.title}</div>
              <div class="col-span-1 text-right text-[var(--color-navy)]">→</div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <div class="border border-[var(--color-rule)] p-8 bg-[var(--color-surface)] text-sm text-[var(--color-ink-muted)] leading-relaxed max-w-2xl">
      The archive of individual editions is being wired up. Meanwhile, the latest edition is always at
      <a href={social.newsletterLanding} target="_blank" rel="noopener" class="ml-1">dcinsights.web.app</a>.
    </div>
  )}
</div>
